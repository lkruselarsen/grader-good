    // Get the average color from the original image in this area
    const imageData = originalCtx.getImageData(area.x, area.y, area.width, area.height)
    const data = imageData.data

    let sumR = 0,
      sumG = 0,
      sumB = 0,
      count = 0

    for (let i = 0; i < data.length; i += 4) {
      if (data[i + 3] > 0) {
        sumR += data[i]
        sumG += data[i + 1]
        sumB += data[i + 2]
        count++
      }
    }

    const avgColor = {
      r: Math.round(sumR / count),
      g: Math.round(sumG / count),
      b: Math.round(sumB / count),
    }

    // Clear the boundary area
    ctx.clearRect(area.x, area.y, area.width, area.height)

    // Create new circles with consistent properties but varied positions
    const circleCount = Math.max(30, Math.floor((area.width * area.height) / 150))

    for (let i = 0; i < circleCount; i++) {
      // Random position within the boundary area
      const x = area.x + Math.random() * area.width
      const y = area.y + Math.random() * area.height

      // Random size between 2 and 9
      const size = 2 + Math.random() * 7

      // Get color from the original image but blend with average
      const originalColor = getColorFromOriginal(originalCtx, x, y, size)
      if (!originalColor) break

      // Blend with average color (80% original, 20% average)
      const r = originalColor.r * 0.8 + avgColor.r * 0.2
      const g = originalColor.g * 0.8 + avgColor.g * 0.2
      const b = originalColor.b * 0.8 + avgColor.b * 0.2

      // Draw the circle
      ctx.beginPath()
      ctx.arc(x, y, size / 2, 0, Math.PI * 2)
      ctx.fillStyle = `rgba(${Math.round(r)}, ${Math.round(g)}, ${Math.round(b)}, ${originalColor.a * 0.7})`
      ctx.fill()
    }
  }

  // Fix a mixed boundary area
  const fixMixedBoundary = async (
    ctx: CanvasRenderingContext2D,
    originalCtx: CanvasRenderingContext2D,
    circlesCtx: CanvasRenderingContext2D,
    allCircles: CircleData[],
    area: { x: number; y: number; width: number; height: number; isHorizontal: boolean },
    transitionZoneWidth: number,
  ) => {
    // For mixed areas, use a circle flow approach

    // Get circles in and around the boundary area
    const expandedArea = {
      x: Math.max(0, area.x - transitionZoneWidth),
      y: Math.max(0, area.y - transitionZoneWidth),
      width: area.width + transitionZoneWidth * 2,
      height: area.height + transitionZoneWidth * 2,
    }

    // Filter circles to only include those in the expanded area
    // Use a more efficient approach for large circle arrays
    const nearbyCircles: CircleData[] = []
    const maxCirclesToProcess = 5000 // Limit to prevent excessive computation
    const circleStep = Math.max(1, Math.floor(allCircles.length / maxCirclesToProcess))

    for (let i = 0; i < allCircles.length; i += circleStep) {
      const circle = allCircles[i]
      if (
        circle.x >= expandedArea.x &&
        circle.x < expandedArea.x + expandedArea.width &&
        circle.y >= expandedArea.y &&
        circle.y < expandedArea.y + expandedArea.height
      ) {
        nearbyCircles.push(circle)
      }
    }

    // Clear the boundary area
    ctx.clearRect(area.x, area.y, area.width, area.height)

    // Create a flow field for circle placement
    const flowField = createFlowField(area.width, area.height, area.isHorizontal)

    // Create new circles following the flow field
    const circleCount = Math.max(40, Math.floor((area.width * area.height) / 120))

    for (let i = 0; i < circleCount; i++) {
      // Start with random position within the boundary area
      let x = Math.random() * area.width
      let y = Math.random() * area.height

      // Follow the flow field for a few steps
      const steps = 3 + Math.floor(Math.random() * 3)
      for (let step = 0; step < steps; step++) {
        const fieldX = Math.floor(x / 10)
        const fieldY = Math.floor(y / 10)

        if (fieldX >= 0 && fieldX < flowField[0].length && fieldY >= 0 && fieldY < flowField.length) {
          const angle = flowField[fieldY][fieldX]
          x += Math.cos(angle) * 3
          y += Math.sin(angle) * 3
        }

        // Keep within bounds
        x = Math.max(0, Math.min(area.width - 1, x))
        y = Math.max(0, Math.min(area.height - 1, y))
      }

      // Random size between 2 and 9
      const size = 2 + Math.random() * 7

      // Get color from the original image
      const originalColor = getColorFromOriginal(originalCtx, area.x + x, area.y + y, size)
      if (!originalColor) break

      // Draw the circle
      ctx.beginPath()
      ctx.arc(area.x + x, area.y + y, size / 2, 0, Math.PI * 2)
      ctx.fillStyle = `rgba(${originalColor.r}, ${originalColor.g}, ${originalColor.b}, ${originalColor.a * 0.7})`
      ctx.fill()
    }
  }

  // Create a flow field for circle placement
  const createFlowField = (width: number, height: number, isHorizontal: boolean): number[][] => {
    const cellSize = 10
    const cols = Math.ceil(width / cellSize)
    const rows = Math.ceil(height / cellSize)

    const field: number[][] = []

    for (let y = 0; y < rows; y++) {
      field[y] = []
      for (let x = 0; x < cols; x++) {
        // Base angle perpendicular to the boundary
        const baseAngle = isHorizontal ? 0 : Math.PI / 2

        // Add Perlin-like noise
        const noiseX = Math.sin(x * 0.2) * Math.cos(y * 0.3)
        const noiseY = Math.sin(y * 0.2) * Math.cos(x * 0.3)
        const noiseAngle = Math.atan2(noiseY, noiseX)

        // Combine base angle with noise
        field[y][x] = baseAngle + noiseAngle * 0.5
      }
    }

    return field
  }

