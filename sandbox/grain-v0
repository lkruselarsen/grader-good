    } catch (error) {
      console.error("Error in fixGlobalBoundaries:", error)
      // Make sure we still return even if there's an error
    }
  }

  // Analyze image content type (detailed, uniform, or mixed)
  const analyzeImageContent = (
    ctx: CanvasRenderingContext2D,
    x: number,
    y: number,
    width: number,
    height: number,
  ): "detailed" | "uniform" | "mixed" => {
    try {
      const imageData = ctx.getImageData(x, y, width, height)
      const data = imageData.data

      // Calculate variance and edge density
      let sumR = 0,
        sumG = 0,
        sumB = 0
      const count = width * height

      // Calculate means
      for (let i = 0; i < data.length; i += 4) {
        sumR += data[i]
        sumG += data[i + 1]
        sumB += data[i + 2]
      }

      const meanR = sumR / count
      const meanG = sumG / count
      const meanB = sumB / count

      // Calculate variances
      let varR = 0,
        varG = 0,
        varB = 0

      for (let i = 0; i < data.length; i += 4) {
        varR += Math.pow(data[i] - meanR, 2)
        varG += Math.pow(data[i + 1] - meanG, 2)
        varB += Math.pow(data[i + 2] - meanB, 2)
      }

      varR /= count
      varG /= count
      varB /= count

      const totalVariance = (varR + varG + varB) / 3

      // Calculate edge density
      let edgeCount = 0
      for (let y = 1; y < height; y += 2) {
        // Sample fewer points
        for (let x = 1; x < width; x += 2) {
          // Sample fewer points
          const idx = (y * width + x) * 4
          const idxLeft = (y * width + (x - 1)) * 4
          const idxUp = ((y - 1) * width + x) * 4

          const diffH =
            Math.abs(data[idx] - data[idxLeft]) +
            Math.abs(data[idx + 1] - data[idxLeft + 1]) +
            Math.abs(data[idx + 2] - data[idxLeft + 2])

          const diffV =
            Math.abs(data[idx] - data[idxUp]) +
            Math.abs(data[idx + 1] - data[idxUp + 1]) +
            Math.abs(data[idx + 2] - data[idxUp + 2])

          if (diffH > 100 || diffV > 100) {
            edgeCount++
          }
        }
      }

      const edgeDensity = edgeCount / ((width / 2 - 1) * (height / 2 - 1))

      // Classify based on variance and edge density
      if (totalVariance > 1000 || edgeDensity > 0.1) {
        return "detailed"
      } else if (totalVariance < 300 && edgeDensity < 0.05) {
        return "uniform"
      } else {
        return "mixed"
      }
    } catch (e) {
      return "mixed" // Default to mixed if analysis fails
    }
  }

  // Fix a detailed boundary area
  const fixDetailedBoundary = async (
    ctx: CanvasRenderingContext2D,
    originalCtx: CanvasRenderingContext2D,
    circlesCtx: CanvasRenderingContext2D,
    allCircles: CircleData[],
    area: { x: number; y: number; width: number; height: number; isHorizontal: boolean },
    transitionZoneWidth: number,
  ) => {
    // For detailed areas, use a combination of statistical matching and Perlin noise

    // Get circles in and around the boundary area
    const expandedArea = {
      x: Math.max(0, area.x - transitionZoneWidth),
      y: Math.max(0, area.y - transitionZoneWidth),
      width: area.width + transitionZoneWidth * 2,
      height: area.height + transitionZoneWidth * 2,
    }

    // Filter circles to only include those in the expanded area
    // Use a more efficient approach for large circle arrays
    const nearbyCircles: CircleData[] = []
    const maxCirclesToProcess = 5000 // Reduced from 10000 to prevent stack overflow
    const circleStep = Math.max(1, Math.floor(allCircles.length / maxCirclesToProcess))

    for (let i = 0; i < allCircles.length; i += circleStep) {
      const circle = allCircles[i]
      if (
        circle.x >= expandedArea.x &&
        circle.x < expandedArea.x + expandedArea.width &&
        circle.y >= expandedArea.y &&
        circle.y < expandedArea.y + expandedArea.height
      ) {
        nearbyCircles.push(circle)
      }
    }

    // Divide into two regions (across the boundary)
    const midpoint = area.isHorizontal ? area.y + area.height / 2 : area.x + area.width / 2

    const regionACircles = nearbyCircles.filter((circle) =>
      area.isHorizontal ? circle.y < midpoint : circle.x < midpoint,
    )

    const regionBCircles = nearbyCircles.filter((circle) =>
      area.isHorizontal ? circle.y >= midpoint : circle.x >= midpoint,
    )

    // Calculate statistics for both regions
    const statsA = calculateCircleStatistics(regionACircles)
    const statsB = calculateCircleStatistics(regionBCircles)

    // Clear the boundary area
    ctx.clearRect(area.x, area.y, area.width, area.height)

    // Create new circles in the boundary area with statistical properties that transition smoothly
    const newCircles: CircleData[] = []
    const circleCount = Math.max(50, Math.floor((area.width * area.height) / 100))

    for (let i = 0; i < circleCount; i++) {
      // Random position within the boundary area
      const x = area.x + Math.random() * area.width
      const y = area.y + Math.random() * area.height

      // Calculate transition factor (0 at one edge, 1 at the other)
      const transitionFactor = area.isHorizontal ? (y - area.y) / area.height : (x - area.x) / area.width

      // Apply Perlin-like noise to the transition factor for more natural blending
      const noiseFactor = 0.7 + 0.3 * Math.sin(x * 0.1) * Math.cos(y * 0.1)
      const adjustedFactor = Math.max(0, Math.min(1, transitionFactor * noiseFactor))

      // Interpolate circle properties between the two regions
      const size = statsA.avgSize * (1 - adjustedFactor) + statsB.avgSize * adjustedFactor
      const sizeVariation = Math.sqrt(statsA.sizeVariance * (1 - adjustedFactor) + statsB.sizeVariance * adjustedFactor)

      // Add some randomness to the size
      const finalSize = Math.max(2, Math.min(9, size + (Math.random() * 2 - 1) * sizeVariation))

      // Get color from the original image with some statistical influence
      const originalColor = getColorFromOriginal(originalCtx, x, y, finalSize)
      if (!originalColor) break

      // Blend with statistical color properties
      const r =
        originalColor.r * 0.7 + (statsA.avgColor.r * (1 - adjustedFactor) + statsB.avgColor.r * adjustedFactor) * 0.3
      const g =
        originalColor.g * 0.7 + (statsA.avgColor.g * (1 - adjustedFactor) + statsB.avgColor.g * adjustedFactor) * 0.3
      const b =
        originalColor.b * 0.7 + (statsA.avgColor.b * (1 - adjustedFactor) + statsB.avgColor.b * adjustedFactor) * 0.3

      // Interpolate opacity
      const opacity = statsA.avgOpacity * (1 - adjustedFactor) + statsB.avgOpacity * adjustedFactor

      // Add the new circle
      newCircles.push({
        x: x - area.x, // Store relative to area
        y: y - area.y,
        size: finalSize,
        r: Math.round(r),
        g: Math.round(g),
        b: Math.round(b),
        a: opacity,
      })
    }

    // Draw the new circles
    newCircles.forEach((circle) => {
      ctx.beginPath()
      ctx.arc(area.x + circle.x + circle.size / 2, area.y + circle.y + circle.size / 2, circle.size / 2, 0, Math.PI * 2)
      ctx.fillStyle = `rgba(${circle.r}, ${circle.g}, ${circle.b}, ${circle.a})`
      ctx.fill()
    })
  }

  // Fix a uniform boundary area
  const fixUniformBoundary = async (
    ctx: CanvasRenderingContext2D,
    originalCtx: CanvasRenderingContext2D,
    circlesCtx: CanvasRenderingContext2D,
    allCircles: CircleData[],
    area: { x: number; y: number; width: number; height: number; isHorizontal: boolean },
    transitionZoneWidth: number,
