"use client"

import { Button } from "@/components/ui/button"
import { Switch } from "@/components/ui/switch"
import { Label } from "@/components/ui/label"
import { Loader2, X } from "lucide-react"
import type React from "react"
import { useState, useRef, useEffect, useCallback } from "react"
import { Slider } from "@/components/ui/slider"
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
  DialogDescription,
  DialogFooter,
} from "@/components/ui/dialog"

interface ImageProcessorProps {
  originalImage: string
  processedImage: string | null
  setProcessedImage: (image: string | null) => void
}

// Interface for circle data
interface CircleData {
  x: number
  y: number
  size: number
  r: number
  g: number
  b: number
  a: number
}

// Interface for boundary analysis
interface BoundaryAnalysis {
  colorDiscontinuity: number
  patternDiscontinuity: number
  densityChange: number
  alignmentScore: number
  textureCoherence: number
  boundaryProbability: number
}

// Interface for circle statistics
interface CircleStatistics {
  avgSize: number
  sizeVariance: number
  avgColor: { r: number; g: number; b: number }
  colorVariance: number
  density: number
  avgOpacity: number
  opacityVariance: number
  dominantDirection: number | null
}

// Interface for processing progress
interface ProcessingProgress {
  stage: string
  tilesProcessed: number
  totalTiles: number
  percentage: number
}

// Interface for halation settings
interface HalationSettings {
  enabled: boolean
  highlightThreshold: number
  shadowThreshold: number
  halationDepth: number
  halationColor: number // 0 = red, 0.5 = orange, 1 = white
  halationOpacity: number // 1-20%, scales down the halation intensity
}

// Calculate dynamic circle sizes based on image resolution
const calculateCircleSizes = (width: number, height: number) => {
  const longestEdge = Math.max(width, height)

  // Base reference: 5000px longest edge = 2-9px diameter
  // Scale linearly based on resolution
  const scaleFactor = longestEdge / 5000

  const minSize = Math.max(1, Math.round(2 * scaleFactor))
  const maxSize = Math.max(minSize + 1, Math.round(9 * scaleFactor))

  return { minSize, maxSize, scaleFactor }
}

export default function ImageProcessor({ originalImage, processedImage, setProcessedImage }: ImageProcessorProps) {
  const [isProcessing, setIsProcessing] = useState(false)
  const [detailPosition, setDetailPosition] = useState({ x: 0, y: 0 })
  const [detailSize] = useState(150)
  const [progress, setProgress] = useState<ProcessingProgress | null>(null)
  const [useTopoOpacity, setUseTopoOpacity] = useState(true) // Default to enabled
  const [highlightOpacity, setHighlightOpacity] = useState(3) // Default to 3%
  const [midtoneOpacity, setMidtoneOpacity] = useState(69) // Default to 69%
  const [shadowOpacity, setShadowOpacity] = useState(84) // Default to 84%
  const [highlightThreshold, setHighlightThreshold] = useState(200) // Default to 200
  const [midtoneThreshold, setMidtoneThreshold] = useState(25) // Default to 25 (below this is shadow)
  const [shadowOvalSize, setShadowOvalSize] = useState(120) // Default to 120%
  const [shadowColorDensity, setShadowColorDensity] = useState(130) // Default to 130%
  const [shadowBrightness, setShadowBrightness] = useState(70) // Default to 70%
  const [halationModalOpen, setHalationModalOpen] = useState(false)
  const [halationSettings, setHalationSettings] = useState<HalationSettings>({
    enabled: true, // Enabled by default
    highlightThreshold: 190,
    shadowThreshold: 100,
    halationDepth: 9, // Base value calibrated for 3040x2024 - scales with image size
    halationColor: 0.4, // Toward red
    halationOpacity: 20,
  })
  const [contourHalationEnabled, setContourHalationEnabled] = useState(true) // Default on
  const [contourHalationStrength, setContourHalationStrength] = useState<1 | 2 | 3>(2) // Default strength 2
  const [fineGrainEnabled, setFineGrainEnabled] = useState(true) // Default on
  const [fineGrainStrength, setFineGrainStrength] = useState<"normal" | "strong">("normal") // Default normal
  const [fineGrainExtraChroma, setFineGrainExtraChroma] = useState(false) // Default off
  const [useAlgo2, setUseAlgo2] = useState(false) // Additive RGB algorithm
  const halationPreviewCanvasRef = useRef<HTMLCanvasElement>(null)
  const [settingsChangedSinceProcess, setSettingsChangedSinceProcess] = useState(false)
  const mainImageRef = useRef<HTMLImageElement>(null)
  const mainCanvasRef = useRef<HTMLCanvasElement>(null)
  const detailCanvasRef = useRef<HTMLCanvasElement>(null)
  const originalImageObj = useRef<HTMLImageElement | null>(null)

  // Initialize the image and set a random detail position
  useEffect(() => {
    const img = new Image()
    img.crossOrigin = "anonymous"
    img.src = originalImage

    img.onload = () => {
      originalImageObj.current = img

      // Set a random position for the detail view
      const randomX = Math.floor(Math.random() * (img.width - detailSize))
      const randomY = Math.floor(Math.random() * (img.height - detailSize))
      setDetailPosition({ x: randomX, y: randomY })

      // Draw the original image
      drawOriginalImage()
    }
  }, [originalImage])

  // Update the detail view when position changes
  useEffect(() => {
    if (originalImageObj.current) {
      if (useTopoOpacity) {
        drawHighlightVisualization()
      } else {
        drawDetailView()
      }
    }
  }, [detailPosition, useTopoOpacity, highlightThreshold, midtoneThreshold])

  // Draw the original image on the main canvas
  const drawOriginalImage = () => {
    if (!mainCanvasRef.current || !originalImageObj.current) return

    const canvas = mainCanvasRef.current
    const ctx = canvas.getContext("2d")
    if (!ctx) return

    const img = originalImageObj.current

    // Set canvas dimensions to match image
    canvas.width = img.width
    canvas.height = img.height

    // Draw the image
    ctx.drawImage(img, 0, 0)
  }

  // Get halation color based on slider value (0 = red, 0.5 = orange, 1 = white)
  const getHalationColor = useCallback((colorValue: number): { r: number; g: number; b: number } => {
    if (colorValue <= 0.5) {
      // Interpolate from red to orange
      const t = colorValue / 0.5
      return {
        r: 255,
        g: Math.round(165 * t), // 0 to 165 (orange green component)
        b: 0,
      }
    } else {
      // Interpolate from orange to white
      const t = (colorValue - 0.5) / 0.5
      return {
        r: 255,
        g: Math.round(165 + (255 - 165) * t), // 165 to 255
        b: Math.round(255 * t), // 0 to 255
      }
    }
  }, [])

  // Draw halation preview in the modal
  const drawHalationPreview = useCallback(() => {
    if (!halationPreviewCanvasRef.current || !originalImageObj.current) return

    const canvas = halationPreviewCanvasRef.current
    const ctx = canvas.getContext("2d")
    if (!ctx) return

    const img = originalImageObj.current

    // Calculate scaled dimensions to fit in preview
    const maxWidth = 800
    const maxHeight = 600
    const scale = Math.min(maxWidth / img.width, maxHeight / img.height, 1)
    const scaledWidth = Math.round(img.width * scale)
    const scaledHeight = Math.round(img.height * scale)

    // Scale halation depth for preview
    const scaledDepth = Math.round(halationSettings.halationDepth * scale)

    canvas.width = scaledWidth
    canvas.height = scaledHeight

    // Draw scaled original image
    ctx.drawImage(img, 0, 0, scaledWidth, scaledHeight)

    // Get image data to find highlight and shadow edges
    const imageData = ctx.getImageData(0, 0, scaledWidth, scaledHeight)
    const data = imageData.data

    // Create brightness map
    const brightnessMap: number[][] = []
    for (let y = 0; y < scaledHeight; y++) {
      brightnessMap[y] = []
      for (let x = 0; x < scaledWidth; x++) {
        const idx = (y * scaledWidth + x) * 4
        brightnessMap[y][x] = Math.round(0.299 * data[idx] + 0.587 * data[idx + 1] + 0.114 * data[idx + 2])
      }
    }

    // First pass: collect all highlight and shadow edge pixels
    const highlightEdges: { x: number; y: number }[] = []
    const shadowEdges: { x: number; y: number }[] = []

    for (let y = 1; y < scaledHeight - 1; y++) {
      for (let x = 1; x < scaledWidth - 1; x++) {
        const brightness = brightnessMap[y][x]
        const isHighlight = brightness > halationSettings.highlightThreshold
        const isShadow = brightness < halationSettings.shadowThreshold

        // Check neighbors for edge detection
        let hasAdjacentDifferent = false
        for (let dy = -1; dy <= 1; dy++) {
          for (let dx = -1; dx <= 1; dx++) {
            if (dx === 0 && dy === 0) continue
            const neighborBrightness = brightnessMap[y + dy][x + dx]

            if (isHighlight && neighborBrightness <= halationSettings.highlightThreshold) {
              hasAdjacentDifferent = true
            }
            if (isShadow && neighborBrightness >= halationSettings.shadowThreshold) {
              hasAdjacentDifferent = true
            }
          }
        }

        if (hasAdjacentDifferent) {
          if (isHighlight) {
            highlightEdges.push({ x, y })
          } else if (isShadow) {
            shadowEdges.push({ x, y })
          }
        }
      }
    }

    // Create overlay canvas
    const overlayCanvas = document.createElement("canvas")
    overlayCanvas.width = scaledWidth
    overlayCanvas.height = scaledHeight
    const overlayCtx = overlayCanvas.getContext("2d")
    if (!overlayCtx) return

    // Second pass: find shadow edges that are within halation depth of highlight edges
    // Create a set for fast lookup of active halation zones
    const activeHalationZones = new Set<string>()

    for (const highlightEdge of highlightEdges) {
      for (const shadowEdge of shadowEdges) {
        const dx = highlightEdge.x - shadowEdge.x
        const dy = highlightEdge.y - shadowEdge.y
        const distance = Math.sqrt(dx * dx + dy * dy)

        if (distance <= scaledDepth) {
          // Mark both as active halation zones
          activeHalationZones.add(`${highlightEdge.x},${highlightEdge.y}`)
          activeHalationZones.add(`${shadowEdge.x},${shadowEdge.y}`)
        }
      }
    }

    // Draw all edges with appropriate colors
    for (const edge of highlightEdges) {
      const isActive = activeHalationZones.has(`${edge.x},${edge.y}`)
      if (isActive) {
        // Active halation zone - yellow/gold
        overlayCtx.fillStyle = "rgba(255, 215, 0, 0.9)"
        overlayCtx.fillRect(edge.x - 1, edge.y - 1, 3, 3)
      } else {
        // Highlight edge - cyan
        overlayCtx.fillStyle = "rgba(0, 255, 255, 0.8)"
        overlayCtx.fillRect(edge.x, edge.y, 2, 2)
      }
    }

    for (const edge of shadowEdges) {
      const isActive = activeHalationZones.has(`${edge.x},${edge.y}`)
      if (isActive) {
        // Active halation zone - yellow/gold
        overlayCtx.fillStyle = "rgba(255, 215, 0, 0.9)"
        overlayCtx.fillRect(edge.x - 1, edge.y - 1, 3, 3)
      } else {
        // Shadow edge - magenta
        overlayCtx.fillStyle = "rgba(255, 0, 255, 0.8)"
        overlayCtx.fillRect(edge.x, edge.y, 2, 2)
      }
    }

    // Draw the overlay on top of the original
    ctx.drawImage(overlayCanvas, 0, 0)

    // Add legend
    ctx.fillStyle = "rgba(0, 0, 0, 0.8)"
    ctx.fillRect(10, scaledHeight - 80, 260, 70)
    ctx.font = "12px sans-serif"
    ctx.fillStyle = "cyan"
    ctx.fillRect(20, scaledHeight - 68, 12, 12)
    ctx.fillStyle = "white"
    ctx.fillText("Highlight edges", 40, scaledHeight - 58)
    ctx.fillStyle = "magenta"
    ctx.fillRect(20, scaledHeight - 48, 12, 12)
    ctx.fillStyle = "white"
    ctx.fillText("Shadow edges", 40, scaledHeight - 38)
    ctx.fillStyle = "gold"
    ctx.fillRect(20, scaledHeight - 28, 12, 12)
    ctx.fillStyle = "white"
    ctx.fillText("Active halation zone", 40, scaledHeight - 18)
  }, [halationSettings])

  // Update halation preview when settings change
  useEffect(() => {
    if (halationModalOpen) {
      drawHalationPreview()
    }
  }, [halationModalOpen, halationSettings, drawHalationPreview])

  // Track settings changes to re-enable the Apply button
  useEffect(() => {
    if (processedImage) {
      setSettingsChangedSinceProcess(true)
    }
  }, [useTopoOpacity, highlightOpacity, midtoneOpacity, shadowOpacity, highlightThreshold, midtoneThreshold, shadowOvalSize, shadowColorDensity, shadowBrightness, halationSettings, useAlgo2])

  // Draw the detail view
  const drawDetailView = () => {
    if (!detailCanvasRef.current || !originalImageObj.current) return

    const canvas = detailCanvasRef.current
    const ctx = canvas.getContext("2d")
    if (!ctx) return

    const img = originalImageObj.current

    // Set canvas dimensions
    canvas.width = detailSize
    canvas.height = detailSize

    // Draw the detail area
    ctx.drawImage(img, detailPosition.x, detailPosition.y, detailSize, detailSize, 0, 0, detailSize, detailSize)

    // If we're showing the processed image, apply the effect to the detail view
    if (processedImage) {
      applyEffectToDetail(ctx)
    }
  }

  // Draw highlight visualization on the detail view
  const drawHighlightVisualization = () => {
    if (!detailCanvasRef.current || !originalImageObj.current) return

    const canvas = detailCanvasRef.current
    const ctx = canvas.getContext("2d")
    if (!ctx) return

    const img = originalImageObj.current

    // Set canvas dimensions
    canvas.width = detailSize
    canvas.height = detailSize

    // Draw the detail area
    ctx.drawImage(img, detailPosition.x, detailPosition.y, detailSize, detailSize, 0, 0, detailSize, detailSize)

    // Get image data to analyze brightness
    const imageData = ctx.getImageData(0, 0, detailSize, detailSize)
    const data = imageData.data

    // Create overlay for highlight visualization
    const overlayData = ctx.createImageData(detailSize, detailSize)
    const overlay = overlayData.data

      for (let i = 0; i < data.length; i += 4) {
        const brightness = Math.round(0.299 * data[i] + 0.587 * data[i + 1] + 0.114 * data[i + 2])
        
        // Set overlay color based on brightness zone
        if (brightness > highlightThreshold) {
          // Highlights - red overlay with varying intensity
          const intensity = Math.min(255, ((brightness - highlightThreshold) / (255 - highlightThreshold)) * 150 + 100)
          overlay[i] = intensity // Red
          overlay[i + 1] = 0 // Green
          overlay[i + 2] = 0 // Blue
          overlay[i + 3] = 80 // Alpha
        } else if (brightness > midtoneThreshold) {
          // Midtones - yellow overlay with varying intensity
          const intensity = Math.min(255, ((brightness - midtoneThreshold) / (highlightThreshold - midtoneThreshold)) * 100 + 80)
          overlay[i] = intensity // Red
          overlay[i + 1] = intensity // Green
          overlay[i + 2] = 0 // Blue
          overlay[i + 3] = 60 // Alpha
        } else {
          // Shadows - blue overlay with varying intensity
          const intensity = Math.min(255, ((midtoneThreshold - brightness) / midtoneThreshold) * 100 + 80)
          overlay[i] = 0 // Red
          overlay[i + 1] = 0 // Green
          overlay[i + 2] = intensity // Blue
          overlay[i + 3] = 50 // Alpha
        }
      }

    // Draw the overlay
    ctx.putImageData(overlayData, 0, 0)

    // If we're showing the processed image, apply the effect to the detail view
    if (processedImage) {
      applyEffectToDetail(ctx)
    }
  }

  // Handle double tap on the main image
  const handleDoubleTap = (e: React.MouseEvent<HTMLDivElement>) => {
    if (!mainImageRef.current || !originalImageObj.current) return

    // Get the click position relative to the image
    const rect = mainImageRef.current.getBoundingClientRect()
    const scaleX = originalImageObj.current.width / rect.width
    const scaleY = originalImageObj.current.height / rect.height

    const x = (e.clientX - rect.left) * scaleX
    const y = (e.clientY - rect.top) * scaleY

    // Center the detail view on the click position
    const newX = Math.max(0, Math.min(x - detailSize / 2, originalImageObj.current.width - detailSize))
    const newY = Math.max(0, Math.min(y - detailSize / 2, originalImageObj.current.height - detailSize))

    setDetailPosition({ x: newX, y: newY })
  }

  // Apply the effect to the detail view
  const applyEffectToDetail = (ctx: CanvasRenderingContext2D) => {
    // This is a simplified version of the effect
    // In a real implementation, we would apply the full effect as described

    const imageData = ctx.getImageData(0, 0, detailSize, detailSize)
    const data = imageData.data

    // Apply a simple effect for demonstration
    // In the real implementation, this would be the tile-by-tile deconstruction
    for (let y = 0; y < detailSize; y += 5) {
      for (let x = 0; x < detailSize; x += 5) {
        const idx = (y * detailSize + x) * 4

        // Create a circle effect
        ctx.beginPath()
        ctx.arc(x, y, 2.5, 0, Math.PI * 2)
        ctx.fillStyle = `rgba(${data[idx]}, ${data[idx + 1]}, ${data[idx + 2]}, 0.7)`
        ctx.fill()
      }
    }
  }

  // Process the entire image with the effect
  const processImage = () => {
    if (!originalImageObj.current) return
    setIsProcessing(true)
    setSettingsChangedSinceProcess(false) // Reset settings change flag
    setProgress({
      stage: "Initializing",
      tilesProcessed: 0,
      totalTiles: 0,
      percentage: 0,
    })

    // Create an offscreen canvas for processing
    const canvas = document.createElement("canvas")
    const ctx = canvas.getContext("2d")
    if (!ctx) {
      setIsProcessing(false)
      return
    }

    const img = originalImageObj.current
    canvas.width = img.width
    canvas.height = img.height

    // Draw the original image
    ctx.drawImage(img, 0, 0)
    
    // For algo2: fill the entire canvas with black backdrop ONCE at the start
    // This prevents any black grid lines between macro tiles
    if (useAlgo2) {
      // Store the original image data before filling with black
      const originalData = ctx.getImageData(0, 0, img.width, img.height)
      ;(ctx as any)._algo2FullSourceData = originalData
      ctx.fillStyle = "rgb(2, 2, 2)"
      ctx.fillRect(0, 0, img.width, img.height)
    }

    // Process the image in chunks to avoid blocking the UI
    setTimeout(() => {
      applyFullEffect(ctx, img.width, img.height)
        .then(() => {
          // Make sure we're setting the processed image with the final canvas data
          const processedImageUrl = canvas.toDataURL("image/png")
          setProcessedImage(processedImageUrl)
          setIsProcessing(false)
          setProgress(null)
          console.log("Processing complete, image URL generated:", processedImageUrl.substring(0, 50) + "...")
        })
        .catch((error) => {
          console.error("Error during image processing:", error)
          setIsProcessing(false)
          setProgress(null)
        })
    }, 100)
  }

  // Apply the full effect to the image
  const applyFullEffect = async (ctx: CanvasRenderingContext2D, width: number, height: number) => {
    // Calculate dynamic circle sizes based on image resolution
    const circleSizes = calculateCircleSizes(width, height)
    console.log(
      `Image resolution: ${width}x${height}, Circle sizes: ${circleSizes.minSize}-${circleSizes.maxSize}px, Scale factor: ${circleSizes.scaleFactor.toFixed(2)}`,
    )

    const tileSize = 150
    const gridSize = 3 // 3x3 grid of tiles
    const macroTileSize = tileSize * gridSize // 450x450 pixels
    const transitionZoneWidth = 25 // Width of transition zone around boundaries

    // Limit the maximum number of circles to prevent stack overflow
    const MAX_CIRCLES = 100000

    // Calculate total number of tiles for progress tracking
    const totalMacroTilesX = Math.ceil(width / macroTileSize)
    const totalMacroTilesY = Math.ceil(height / macroTileSize)
    const totalMacroTiles = totalMacroTilesX * totalMacroTilesY
    let macroTilesProcessed = 0

    // Update progress
    setProgress({
      stage: "Preparing",
      tilesProcessed: 0,
      totalTiles: totalMacroTiles,
      percentage: 0,
    })

    // Store a copy of the original image for reference
    const originalCanvasEl = document.createElement("canvas")
    originalCanvasEl.width = width
    originalCanvasEl.height = height
    const originalCtx = originalCanvasEl.getContext("2d")
    if (!originalCtx) return
    originalCtx.drawImage(ctx.canvas, 0, 0)

    // Create a result canvas to build the final image
    const resultCanvas = document.createElement("canvas")
    resultCanvas.width = width
    resultCanvas.height = height
    const resultCtx = resultCanvas.getContext("2d")
    if (!resultCtx) return

    // For algo2: fill resultCtx with near-black backdrop and store source data
    if (useAlgo2) {
      resultCtx.fillStyle = "rgb(2, 2, 2)"
      resultCtx.fillRect(0, 0, width, height)
      // Store the original source data for algo2 to reference
      ;(resultCtx as any)._algo2SourceData = (ctx as any)._algo2FullSourceData
    }

    // Create a verification canvas to track processed areas
    const verificationCanvas = document.createElement("canvas")
    verificationCanvas.width = width
    verificationCanvas.height = height
    const verificationCtx = verificationCanvas.getContext("2d")
    if (!verificationCtx) return
    verificationCtx.fillStyle = "rgba(255, 0, 0, 0.5)" // Red for unprocessed areas

    // Fill the verification canvas with red (unprocessed)
    verificationCtx.fillRect(0, 0, width, height)

    // Create a heat map for boundary probability
    const boundaryHeatMap: number[][] = []
    for (let y = 0; y < height; y++) {
      boundaryHeatMap[y] = new Array(width).fill(0)
    }

    // Store all circles for later analysis
    const allCircles: CircleData[] = []

    // Process the image in chunks to avoid memory issues
    const chunkSize = 1 // Process 1x1 macro tiles at a time to reduce memory usage
    const totalChunksX = Math.ceil(totalMacroTilesX / chunkSize)
    const totalChunksY = Math.ceil(totalMacroTilesY / chunkSize)
    const totalChunks = totalChunksX * totalChunksY

    setProgress({
      stage: "Processing image in chunks",
      tilesProcessed: 0,
      totalTiles: totalChunks,
      percentage: 0,
    })

    let chunksProcessed = 0

    // Process in chunks to manage memory
    for (let chunkY = 0; chunkY < totalChunksY; chunkY++) {
      for (let chunkX = 0; chunkX < totalChunksX; chunkX++) {
        // Process this chunk of macro tiles
        const startMacroX = chunkX * chunkSize * macroTileSize
        const startMacroY = chunkY * chunkSize * macroTileSize
        const chunkWidth = Math.min(chunkSize * macroTileSize, width - startMacroX)
        const chunkHeight = Math.min(chunkSize * macroTileSize, height - startMacroY)

        // Update progress
        setProgress({
          stage: "Processing chunk",
          tilesProcessed: chunksProcessed,
          totalTiles: totalChunks,
          percentage: Math.round((chunksProcessed / totalChunks) * 100),
        })

        // Process macro tiles within this chunk
        const chunkCircles = await processChunk(
          originalCtx,
          resultCtx,
          verificationCtx,
          boundaryHeatMap,
          startMacroX,
          startMacroY,
          chunkWidth,
          chunkHeight,
          tileSize,
          macroTileSize,
          (processed) => {
            macroTilesProcessed += processed
            setProgress({
              stage: "Processing tiles",
              tilesProcessed: macroTilesProcessed,
              totalTiles: totalMacroTiles,
              percentage: Math.round((macroTilesProcessed / totalMacroTiles) * 100),
            })
          },
          MAX_CIRCLES,
          circleSizes,
          useAlgo2 ? (ctx as any)._algo2FullSourceData : undefined,
        )

        // Add circles from this chunk to the global collection, but limit total count
        if (allCircles.length < MAX_CIRCLES) {
          const spaceLeft = MAX_CIRCLES - allCircles.length
          if (chunkCircles.length <= spaceLeft) {
            allCircles.push(...chunkCircles)
          } else {
            allCircles.push(...chunkCircles.slice(0, spaceLeft))
          }
        }

        // Release memory by clearing references
        chunksProcessed++

        // Yield to browser to prevent UI freezing and allow garbage collection
        await new Promise((resolve) => setTimeout(resolve, 10))
      }
    }

    // Skip verification and boundary fixing for algo2 - these would lift shadows
    // Algo2 relies on the random sampling to achieve coverage
    if (!useAlgo2) {
      // Check for unprocessed areas and fix them
      setProgress({
        stage: "Verifying complete coverage",
        tilesProcessed: chunksProcessed,
        totalTiles: totalChunks + 1, // +1 for verification step
        percentage: Math.round((chunksProcessed / (totalChunks + 1)) * 100),
      })

      await verifyAndFixUnprocessedAreas(originalCtx, resultCtx, verificationCtx, width, height, tileSize, circleSizes)

      // Fix boundaries between tiles
      setProgress({
        stage: "Fixing boundaries",
        tilesProcessed: chunksProcessed + 1,
        totalTiles: totalChunks + 2, // +2 for verification and boundary fixing
        percentage: Math.round(((chunksProcessed + 1) / (totalChunks + 2)) * 100),
      })

      // Create a circles canvas for boundary analysis
      const circlesCanvas = document.createElement("canvas")
      circlesCanvas.width = width
      circlesCanvas.height = height
      const circlesCtx = circlesCanvas.getContext("2d")
      if (circlesCtx) {
        // Draw all circles to the circles canvas
        drawCirclesToCanvas(circlesCtx, allCircles)

        // Fix boundaries
        await fixGlobalBoundaries(
          resultCtx,
        circlesCtx,
        originalCtx,
        boundaryHeatMap,
        allCircles,
        width,
        height,
        tileSize,
        macroTileSize,
        transitionZoneWidth,
      )
    }
    } // End of !useAlgo2 block for verification and boundary fixing

    // Final progress update
    setProgress({
      stage: "Finalizing",
      tilesProcessed: chunksProcessed + 2,
      totalTiles: totalChunks + 2,
      percentage: 100,
    })

    // Copy the result back to the main canvas
    ctx.clearRect(0, 0, width, height)
    ctx.drawImage(resultCanvas, 0, 0)

    // FINAL STEP: Layer the processed image on top of the original image
    // This eliminates "see through" gridlines by ensuring transparent areas blend with the original
    const finalCanvas = document.createElement("canvas")
    finalCanvas.width = width
    finalCanvas.height = height
    const finalCtx = finalCanvas.getContext("2d")

    if (finalCtx) {
      if (useAlgo2) {
        // Algo2: Blend pointillist output with original using exposure-based opacity
        // Darker areas show more pointillist effect, brighter areas show more original
        setProgress({
          stage: "Applying exposure-based blend",
          tilesProcessed: chunksProcessed + 2,
          totalTiles: totalChunks + 3,
          percentage: 95,
        })

        // Get pixel data from ORIGINAL SOURCE (for exposure zone calculation)
        // For algo2, the original is stored in _algo2FullSourceData since ctx was filled with black
        const originalImageData = (ctx as any)._algo2FullSourceData as ImageData
        const originalPixels = originalImageData.data
        
        // Get pixel data from PROCESSED pointillist output
        const processedImageData = ctx.getImageData(0, 0, width, height)
        const processedPixels = processedImageData.data
        
        // Create output image data
        const finalImageData = finalCtx.createImageData(width, height)
        const finalPixels = finalImageData.data

        // Exposure zones and their opacity values for the pointillist layer
        // These are based on the ORIGINAL source image brightness
        // Lower exposure = higher opacity (show more pointillist)
        // Higher exposure = lower opacity (show more original)
        const exposureZones = [
          { threshold: 0, opacity: 0.63 },        // Darkest
          { threshold: 1 / 50, opacity: 0.63 },   // Lower 1/50th
          { threshold: 1 / 20, opacity: 0.45 },   // Lower 1/20th
          { threshold: 1 / 10, opacity: 0.35 },   // Lower 1/10th
          { threshold: 1 / 5, opacity: 0.17 },    // Lower 1/5th
          { threshold: 0.5, opacity: 0.11 },      // Midtones
          { threshold: 1.0, opacity: 0.04 },      // Top Highlights
        ]

        // Function to get interpolated opacity based on brightness from ORIGINAL source
        const getOpacityForBrightness = (brightness: number): number => {
          const normalizedBrightness = brightness / 255
          
          // Find the two zones we're between and interpolate
          for (let i = 0; i < exposureZones.length - 1; i++) {
            if (normalizedBrightness <= exposureZones[i + 1].threshold) {
              const lowerZone = exposureZones[i]
              const upperZone = exposureZones[i + 1]
              // Handle case where thresholds are equal
              if (upperZone.threshold === lowerZone.threshold) {
                return lowerZone.opacity
              }
              const t = (normalizedBrightness - lowerZone.threshold) / (upperZone.threshold - lowerZone.threshold)
              // Smooth interpolation using smoothstep
              const smoothT = t * t * (3 - 2 * t)
              return lowerZone.opacity + (upperZone.opacity - lowerZone.opacity) * smoothT
            }
          }
          return exposureZones[exposureZones.length - 1].opacity
        }

        // Debug: log sample values
        let debugCount = 0
        const debugSamples: { brightness: number; opacity: number; origR: number; procR: number; finalR: number }[] = []

        // Blend each pixel
        for (let i = 0; i < finalPixels.length; i += 4) {
          // Get brightness from ORIGINAL source image (not processed)
          const origR = originalPixels[i]
          const origG = originalPixels[i + 1]
          const origB = originalPixels[i + 2]
          const brightness = (origR + origG + origB) / 3

          // Get opacity for pointillist layer based on exposure zone of ORIGINAL
          const pointillistOpacity = getOpacityForBrightness(brightness)

          // Blend: final = original * (1 - opacity) + processed * opacity
          const finalR = Math.round(origR * (1 - pointillistOpacity) + processedPixels[i] * pointillistOpacity)
          const finalG = Math.round(origG * (1 - pointillistOpacity) + processedPixels[i + 1] * pointillistOpacity)
          const finalB = Math.round(origB * (1 - pointillistOpacity) + processedPixels[i + 2] * pointillistOpacity)
          
          finalPixels[i] = finalR
          finalPixels[i + 1] = finalG
          finalPixels[i + 2] = finalB
          finalPixels[i + 3] = 255 // Full alpha

          // Collect debug samples for bright pixels
          if (debugCount < 10 && brightness > 200) {
            debugSamples.push({ brightness, opacity: pointillistOpacity, origR, procR: processedPixels[i], finalR })
            debugCount++
          }
        }

        console.log("[v0] Exposure-based blend applied. Sample bright pixels:", debugSamples)
        console.log("[v0] Expected: high brightness -> low opacity (~0.04), final should be close to original")

        finalCtx.putImageData(finalImageData, 0, 0)
      } else if (useTopoOpacity) {
        // Create topographic opacity map based on original image brightness
        setProgress({
          stage: "Creating topographic opacity map",
          tilesProcessed: chunksProcessed + 2,
          totalTiles: totalChunks + 3,
          percentage: 95,
        })

        // Generate the opacity map
        const opacityMap = await createTopoOpacityMap(originalCtx, width, height)

        // Apply the processed image with variable opacity based on the map
        await applyProcessedImageWithTopoMap(finalCtx, ctx.canvas, originalCtx, opacityMap, width, height)

        console.log("Applied topographic opacity map to final image")
      } else {
        // Standard layering without topographic opacity
        // First draw the original image as the background layer
        finalCtx.drawImage(originalCtx.canvas, 0, 0)

        // Then draw the processed image on top with normal composition
        finalCtx.drawImage(ctx.canvas, 0, 0)
      }

      // Apply halation effect if enabled (skip for algo2 - it doesn't use halation)
      if (!useAlgo2) {
        // Apply contour halation first (fine edge detail)
        if (contourHalationEnabled) {
          setProgress({
            stage: "Applying contour halation",
            tilesProcessed: chunksProcessed + 3,
            totalTiles: totalChunks + 5,
            percentage: 94,
          })
          
          await applyContourHalationEffect(finalCtx, originalCtx, width, height, contourHalationStrength)
        }
        
        // Apply main halation effect (soft glow)
        if (halationSettings.enabled) {
          setProgress({
            stage: "Applying halation glow",
            tilesProcessed: chunksProcessed + 4,
            totalTiles: totalChunks + 5,
            percentage: 97,
          })
          
          await applyHalationEffect(finalCtx, originalCtx, width, height, circleSizes)
        }
      }
  
  // Apply fine grain effect (ISO 800 film grain simulation)
  if (fineGrainEnabled) {
  setProgress({
  stage: "Applying fine grain",
  tilesProcessed: chunksProcessed + 5,
  totalTiles: totalChunks + 6,
  percentage: 99,
  })
  
  await applyFineGrainEffect(finalCtx, width, height, fineGrainStrength, fineGrainExtraChroma)
  }
  
  // Copy the final result back to the main canvas
  ctx.clearRect(0, 0, width, height)
  ctx.drawImage(finalCanvas, 0, 0)
    }
  }

  // Apply contour halation effect - organic, randomized edge effect at highlight/shadow boundaries
  // Creates a fine, splotchy, organic edge on the shadow side of highlight boundaries
  const applyContourHalationEffect = async (
    ctx: CanvasRenderingContext2D,
    originalCtx: CanvasRenderingContext2D,
    width: number,
    height: number,
    strength: 1 | 2 | 3,
  ) => {
    const originalData = originalCtx.getImageData(0, 0, width, height)
    const data = originalData.data
    
    // Create brightness map
    const brightnessMap = new Uint8Array(width * height)
    for (let i = 0; i < width * height; i++) {
      const idx = i * 4
      brightnessMap[i] = Math.round(0.299 * data[idx] + 0.587 * data[idx + 1] + 0.114 * data[idx + 2])
    }
    
    // Use halation settings for thresholds as BASE, then EXPAND the range for higher strength
    // Higher strength = finds MORE contours by lowering the highlight bar and raising the shadow ceiling
    // This ensures all major halation areas are always covered, plus additional areas at higher strengths
    const sensitivityAdjust = [0, 10, 25][strength - 1] // mode 1 = base, mode 2 = bit more, mode 3 = most
    // Lower highlight threshold = more pixels count as highlights (easier to find)
    // Higher shadow threshold = more pixels count as shadows (wider shadow range)
    const highlightThresh = halationSettings.highlightThreshold - sensitivityAdjust
    const shadowThresh = Math.min(180, halationSettings.shadowThreshold + sensitivityAdjust * 1.5)
    
    // Get processed image data to modify
    const processedData = ctx.getImageData(0, 0, width, height)
    const pixels = processedData.data
    
    // Strength affects: depth, opacity, and color intensity
    // Scale with image size for consistent appearance
    const referenceSize = 3040
    const longestEdge = Math.max(width, height)
    const imageScale = longestEdge / referenceSize
    
    const baseDepth = [2, 4, 8][strength - 1] // pixels of edge depth - mode 3 now stronger
    const depthMultiplier = Math.max(baseDepth, Math.round(baseDepth * imageScale))
    const opacityMultiplier = [0.3, 0.5, 0.85][strength - 1] // mode 3 now stronger
    const colorVariation = [0.15, 0.25, 0.4][strength - 1] // mode 3 now stronger
    
    // Find highlight/shadow boundary pixels (shadow pixels adjacent to highlights)
    // and apply organic, randomized halation
    for (let y = 1; y < height - 1; y++) {
      for (let x = 1; x < width - 1; x++) {
        const idx = y * width + x
        const brightness = brightnessMap[idx]
        
        // Only process shadow pixels
        if (brightness >= shadowThresh) continue
        
        // Check if this shadow pixel is near a highlight
        let nearHighlight = false
        let minDistToHighlight = depthMultiplier + 1
        
        // Check in a small radius for highlights
        const searchRadius = depthMultiplier + 2
        for (let dy = -searchRadius; dy <= searchRadius && !nearHighlight; dy++) {
          for (let dx = -searchRadius; dx <= searchRadius; dx++) {
            const nx = x + dx
            const ny = y + dy
            if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue
            
            const nIdx = ny * width + nx
            if (brightnessMap[nIdx] > highlightThresh) {
              const dist = Math.sqrt(dx * dx + dy * dy)
              if (dist < minDistToHighlight) {
                minDistToHighlight = dist
                nearHighlight = true
              }
            }
          }
        }
        
        if (!nearHighlight || minDistToHighlight > depthMultiplier) continue
        
        // Calculate effect intensity based on distance (closer = stronger)
        const distanceFactor = 1 - (minDistToHighlight / depthMultiplier)
        
        // Add randomness for organic look
        const random1 = Math.random()
        const random2 = Math.random()
        const random3 = Math.random()
        
        // Randomize whether this pixel gets the effect (creates splotchy look)
        // More likely near the edge, less likely further away
        const splotchThreshold = 0.3 + distanceFactor * 0.5
        if (random1 > splotchThreshold) continue
        
        // Randomize the intensity for organic variation
        const intensityVariation = 0.5 + random2 * 0.5
        const finalIntensity = distanceFactor * opacityMultiplier * intensityVariation
        
        // Randomize color between orange-red shades
        // Base: warm red-orange, varies per pixel for organic look
        const colorShift = (random3 - 0.5) * colorVariation
        const baseHue = halationSettings.halationColor + colorShift // Shift within orange-red range
        const clampedHue = Math.max(0, Math.min(1, baseHue))
        
        // Convert hue-like value to RGB (red to orange to amber range)
        // 0 = deep red (255, 80, 40), 1 = warm white (255, 220, 180)
        const warmR = 255
        const warmG = 80 + clampedHue * 140 // 80-220
        const warmB = 40 + clampedHue * 140 // 40-180
        
        // Apply to pixel with additive blend
        const pixelIdx = idx * 4
        const baseR = pixels[pixelIdx]
        const baseG = pixels[pixelIdx + 1]
        const baseB = pixels[pixelIdx + 2]
        
        // Additive blend with warm color
        pixels[pixelIdx] = Math.min(255, Math.round(baseR + warmR * finalIntensity * 0.5))
        pixels[pixelIdx + 1] = Math.min(255, Math.round(baseG + warmG * finalIntensity * 0.3))
        pixels[pixelIdx + 2] = Math.min(255, Math.round(baseB + warmB * finalIntensity * 0.15))
      }
    }
    
    ctx.putImageData(processedData, 0, 0)
  }

  // Apply fine grain effect - simulates ISO 800 film grain with chrominance
  // Key characteristics: fine luminance grain, larger chrominance grain, more visible in shadows
  const applyFineGrainEffect = async (
    ctx: CanvasRenderingContext2D,
    width: number,
    height: number,
    strength: "normal" | "strong",
    extraChroma: boolean,
  ) => {
    const processedData = ctx.getImageData(0, 0, width, height)
    const pixels = processedData.data
    
    // Create brightness map for shadow detection
    const brightnessMap = new Uint8Array(width * height)
    for (let i = 0; i < width * height; i++) {
      const idx = i * 4
      brightnessMap[i] = Math.round(0.299 * pixels[idx] + 0.587 * pixels[idx + 1] + 0.114 * pixels[idx + 2])
    }
    
    // Grain size scales with image size - calibrated for 3040x2024 reference
    // For ISO 800, grain should be visible but not overwhelming
    // The grain "cluster" size should be proportional to image resolution
    // so grain appears the same relative size on any image
    const referenceSize = 3040
    const longestEdge = Math.max(width, height)
    const imageScale = longestEdge / referenceSize
    
    // Base grain size for ISO 800 at reference resolution is ~2px
    // Scale proportionally with image size so grain looks same relative size
    const baseGrainSize = Math.max(1, Math.round(2 * imageScale))
    
    // Strength multipliers - scale DOWN for larger images to maintain consistent visual appearance
    // Normal mode is more subtle, strong mode is more pronounced
    const sizeNormalization = 1 / Math.sqrt(imageScale) // Inverse square root scaling
    const strengthMultiplier = (strength === "strong" ? 1.4 : 0.45) * sizeNormalization
    const chromaMultiplier = extraChroma ? 2.0 : 1.0
    
    // Generate grain at a smaller resolution then scale up (more realistic)
    const grainWidth = Math.ceil(width / baseGrainSize)
    const grainHeight = Math.ceil(height / baseGrainSize)
    
    // Luminance grain - fine, subtle
    const luminanceGrain = new Float32Array(grainWidth * grainHeight)
    // Chrominance grain - larger, blurrier (separate for R and B channels)
    const chromaGrainR = new Float32Array(grainWidth * grainHeight)
    const chromaGrainB = new Float32Array(grainWidth * grainHeight)
    
    // Generate random grain patterns
    for (let i = 0; i < grainWidth * grainHeight; i++) {
      // Luminance: Gaussian-ish distribution centered at 0
      luminanceGrain[i] = (Math.random() - 0.5) * 2
      // Chroma: Also centered at 0, affects color
      chromaGrainR[i] = (Math.random() - 0.5) * 2
      chromaGrainB[i] = (Math.random() - 0.5) * 2
    }
    
    // Apply a simple blur to chroma grain for more realistic look
    // Real film has larger chroma grain clusters
    const blurredChromaR = new Float32Array(grainWidth * grainHeight)
    const blurredChromaB = new Float32Array(grainWidth * grainHeight)
    
    for (let y = 0; y < grainHeight; y++) {
      for (let x = 0; x < grainWidth; x++) {
        const idx = y * grainWidth + x
        let sumR = 0, sumB = 0, count = 0
        
        // Simple 3x3 blur for chroma
        for (let dy = -1; dy <= 1; dy++) {
          for (let dx = -1; dx <= 1; dx++) {
            const nx = x + dx
            const ny = y + dy
            if (nx >= 0 && nx < grainWidth && ny >= 0 && ny < grainHeight) {
              const nIdx = ny * grainWidth + nx
              sumR += chromaGrainR[nIdx]
              sumB += chromaGrainB[nIdx]
              count++
            }
          }
        }
        
        blurredChromaR[idx] = sumR / count
        blurredChromaB[idx] = sumB / count
      }
    }
    
    // Apply grain to image pixels
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const pixelIdx = (y * width + x) * 4
        const brightness = brightnessMap[y * width + x]
        
        // Grain visibility: strong in shadows, weak in highlights
        // ISO 800 film: grain very visible in shadows (0-80), moderate in midtones, almost invisible in highlights (200+)
        let grainVisibility: number
        if (brightness < 60) {
          // Deep shadows - maximum grain
          grainVisibility = 1.0
        } else if (brightness < 120) {
          // Lower midtones - still visible
          grainVisibility = 1.0 - ((brightness - 60) / 60) * 0.4
        } else if (brightness < 180) {
          // Upper midtones - reduced
          grainVisibility = 0.6 - ((brightness - 120) / 60) * 0.35
        } else {
          // Highlights - very subtle
          grainVisibility = 0.25 - ((brightness - 180) / 75) * 0.2
          grainVisibility = Math.max(0.05, grainVisibility)
        }
        
        // Sample grain at scaled position
        const gx = Math.floor(x / baseGrainSize)
        const gy = Math.floor(y / baseGrainSize)
        const grainIdx = gy * grainWidth + gx
        
        // Get grain values
        const lumGrain = luminanceGrain[grainIdx]
        const chrR = blurredChromaR[grainIdx]
        const chrB = blurredChromaB[grainIdx]
        
        // Calculate grain amounts
        // Luminance grain: affects all channels equally
        const lumAmount = lumGrain * 15 * strengthMultiplier * grainVisibility
        
        // Chroma grain: affects R and B differently for color shifts
        // Real film grain has slight color variations
        const chromaAmount = 8 * strengthMultiplier * chromaMultiplier * grainVisibility
        
        // Apply grain
        const baseR = pixels[pixelIdx]
        const baseG = pixels[pixelIdx + 1]
        const baseB = pixels[pixelIdx + 2]
        
        // Add luminance + chroma grain
        // R channel: luminance + red chroma
        // G channel: luminance only (less chroma in green for realism)
        // B channel: luminance + blue chroma
        pixels[pixelIdx] = Math.max(0, Math.min(255, Math.round(baseR + lumAmount + chrR * chromaAmount)))
        pixels[pixelIdx + 1] = Math.max(0, Math.min(255, Math.round(baseG + lumAmount * 0.9)))
        pixels[pixelIdx + 2] = Math.max(0, Math.min(255, Math.round(baseB + lumAmount + chrB * chromaAmount)))
      }
    }
    
    ctx.putImageData(processedData, 0, 0)
  }

  // Apply halation effect - EDGE-BASED approach for realistic film halation
  // Real halation: harsh red fringe at boundaries, grainy texture, white-red transition
  const applyHalationEffect = async (
    ctx: CanvasRenderingContext2D,
    originalCtx: CanvasRenderingContext2D,
    width: number,
    height: number,
    circleSizes: { small: number; mid: number; large: number; scaleFactor: number },
  ) => {
    const originalData = originalCtx.getImageData(0, 0, width, height).data
    
    // Create brightness map from original image
    const brightnessMap = new Uint8Array(width * height)
    for (let i = 0; i < width * height; i++) {
      const idx = i * 4
      brightnessMap[i] = Math.round(0.299 * originalData[idx] + 0.587 * originalData[idx + 1] + 0.114 * originalData[idx + 2])
    }
    
    // Scale based on image size
    const referenceSize = 3040
    const longestEdge = Math.max(width, height)
    const imageScaleFactor = longestEdge / referenceSize
    const halationDepth = Math.max(3, Math.round(halationSettings.halationDepth * imageScaleFactor))
    
    // Find highlight and shadow edges
    const highlightThresh = halationSettings.highlightThreshold
    const shadowThresh = halationSettings.shadowThreshold
    
    // Create local contrast map to detect hard edges vs gradual gradients
    // High contrast = hard edge (apply halation), low contrast = gradient (skip)
    const localContrast = new Float32Array(width * height)
    const sampleRadius = Math.max(2, Math.round(3 * imageScaleFactor))
    
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const idx = y * width + x
        const centerBrightness = brightnessMap[idx]
        
        let maxDiff = 0
        // Sample in a small radius to find maximum brightness difference
        for (let dy = -sampleRadius; dy <= sampleRadius; dy++) {
          for (let dx = -sampleRadius; dx <= sampleRadius; dx++) {
            if (dx === 0 && dy === 0) continue
            const nx = x + dx
            const ny = y + dy
            if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue
            
            const nIdx = ny * width + nx
            const diff = Math.abs(brightnessMap[nIdx] - centerBrightness)
            if (diff > maxDiff) maxDiff = diff
          }
        }
        localContrast[idx] = maxDiff
      }
    }
    
    // Create distance-to-highlight map for shadow pixels
    // This tells us how far each shadow pixel is from the nearest highlight
    const distanceToHighlight = new Float32Array(width * height)
    distanceToHighlight.fill(999999)
    
    // Also track the intensity of the nearest highlight (how far above threshold)
    const nearestHighlightIntensity = new Float32Array(width * height)
    
    // First pass: mark highlight pixels and store their intensity
    const highlightPixels: {idx: number, intensity: number}[] = []
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const idx = y * width + x
        const brightness = brightnessMap[idx]
        if (brightness > highlightThresh) {
          // Intensity: how much above threshold (0-1 scale where 1 = pure white 255)
          const intensity = (brightness - highlightThresh) / (255 - highlightThresh)
          highlightPixels.push({idx, intensity})
          distanceToHighlight[idx] = 0
          nearestHighlightIntensity[idx] = intensity
        }
      }
    }
    
    if (highlightPixels.length === 0) return
    
    // BFS to calculate distance from each pixel to nearest highlight
    // Also propagate highlight intensity for thickness calculation
    const maxDist = halationDepth + 6
    const queue: {idx: number, dist: number, intensity: number}[] = highlightPixels.map(h => ({idx: h.idx, dist: 0, intensity: h.intensity}))
    const visited = new Set<number>(highlightPixels.map(h => h.idx))
    
    while (queue.length > 0) {
      const {idx, dist, intensity} = queue.shift()!
      if (dist >= maxDist) continue
      
      const x = idx % width
      const y = Math.floor(idx / width)
      
      // Check 8 neighbors
      for (let dy = -1; dy <= 1; dy++) {
        for (let dx = -1; dx <= 1; dx++) {
          if (dx === 0 && dy === 0) continue
          const nx = x + dx
          const ny = y + dy
          if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue
          
          const nIdx = ny * width + nx
          if (visited.has(nIdx)) continue
          
          const newDist = dist + (dx !== 0 && dy !== 0 ? 1.414 : 1)
          if (newDist < distanceToHighlight[nIdx]) {
            distanceToHighlight[nIdx] = newDist
            nearestHighlightIntensity[nIdx] = intensity // Propagate highlight intensity
            visited.add(nIdx)
            queue.push({idx: nIdx, dist: newDist, intensity})
          }
        }
      }
    }
    
    // Get processed image data to modify
    const processedData = ctx.getImageData(0, 0, width, height)
    const pixels = processedData.data
    
    // Opacity and color settings
    const baseOpacity = (halationSettings.halationOpacity / 100) * 2.5
    const colorSetting = halationSettings.halationColor // 0 = red, 1 = white
    
    // Create shadow proximity map - halation only appears where shadows meet highlights
    // This prevents false halation in sky gradients where there are no dark objects
    const nearShadow = new Uint8Array(width * height)
    const shadowCheckRadius = Math.max(3, Math.round(halationDepth * 1.5))
    
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const idx = y * width + x
        // Check if this pixel or nearby pixels are shadows
        let foundShadow = false
        for (let dy = -shadowCheckRadius; dy <= shadowCheckRadius && !foundShadow; dy++) {
          for (let dx = -shadowCheckRadius; dx <= shadowCheckRadius && !foundShadow; dx++) {
            const nx = x + dx
            const ny = y + dy
            if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue
            const nIdx = ny * width + nx
            if (brightnessMap[nIdx] < shadowThresh) {
              foundShadow = true
            }
          }
        }
        nearShadow[idx] = foundShadow ? 1 : 0
      }
    }
    
    // Apply halation effect
    for (let i = 0; i < width * height; i++) {
      const dist = distanceToHighlight[i]
      if (dist === 0 || dist > maxDist) continue
      
      // CHECK 1: Must be near a shadow area - real halation only appears where dark objects meet bright areas
      // This prevents false halation in sky gradients
      if (nearShadow[i] === 0) continue
      
      // CHECK 2: Skip very gradual gradients - only apply on hard edges
      const contrast = localContrast[i]
      const contrastThreshold = 40
      if (contrast < contrastThreshold) continue
      
      // Reduce effect on medium-contrast areas (soft edges)
      const contrastFactor = Math.min(1, (contrast - contrastThreshold) / 60)
      
      // CHECK 2: Get highlight intensity - affects thickness and strength
      // Blown-out highlights (intensity ~1) get full thick halation
      // Weaker highlights (intensity ~0.2) get thinner, less pronounced halation
      const highlightIntensity = nearestHighlightIntensity[i]
      const intensityThicknessFactor = 0.3 + highlightIntensity * 0.7 // 0.3-1.0 based on highlight strength
      
      const brightness = brightnessMap[i]
      const pixelIdx = i * 4
      
      const baseR = pixels[pixelIdx]
      const baseG = pixels[pixelIdx + 1]
      const baseB = pixels[pixelIdx + 2]
      
      // Calculate effect intensity based on distance
      // Adjust effective edge zone based on highlight intensity
      const effectiveEdgeZone = 6 * imageScaleFactor * intensityThicknessFactor
      const effectiveDepth = halationDepth * intensityThicknessFactor
      
      // Strongest at edge (dist ~1), fading outward
      let intensity: number
      const isEdgeZone = dist <= effectiveEdgeZone
      
      if (isEdgeZone) {
        // HARSH EDGE ZONE - first ~6 pixels (scaled by highlight intensity)
        // Very strong, concentrated red/orange effect
        intensity = 1.0 - (dist / effectiveEdgeZone) * 0.3
      } else if (dist <= effectiveDepth) {
        // TRANSITION ZONE - between edge and depth
        intensity = 0.7 * (1 - (dist - effectiveEdgeZone) / (effectiveDepth - effectiveEdgeZone + 0.1))
      } else if (dist <= maxDist) {
        // SOFT BLOOM ZONE - beyond depth setting (only for strong highlights)
        intensity = 0.15 * highlightIntensity * (1 - (dist - effectiveDepth) / 6)
      } else {
        intensity = 0
      }
      
      if (intensity <= 0) continue
      
      // Apply contrast factor - reduce effect on softer edges
      intensity *= contrastFactor
      
      // Adjust intensity based on pixel brightness
      // More visible in shadows, less in midtones/highlights
      let brightnessMultiplier: number
      if (brightness < shadowThresh) {
        // Shadow - full effect
        brightnessMultiplier = 1.0
      } else if (brightness < 150) {
        // Midtone - reduced
        brightnessMultiplier = 1.0 - ((brightness - shadowThresh) / (150 - shadowThresh)) * 0.5
      } else if (brightness < highlightThresh) {
        // Upper midtone - subtle warm glow on highlight side
        brightnessMultiplier = 0.5 - ((brightness - 150) / (highlightThresh - 150)) * 0.3
      } else {
        // Inside highlight - add bright white/warm fringe
        brightnessMultiplier = 0.4
      }
      
      const finalIntensity = intensity * baseOpacity * brightnessMultiplier
      
      // Add randomness for grainy texture (like real film)
      const random = Math.random()
      const grainFactor = 0.7 + random * 0.6 // 0.7-1.3 random variation
      const grainedIntensity = finalIntensity * grainFactor
      
      // Determine color based on zone and settings
      let addR: number, addG: number, addB: number
      
      if (brightness >= highlightThresh) {
        // ON HIGHLIGHT SIDE - bright white/warm fringe interspersed
        // This creates the white-red boundary effect
        if (random > 0.5) {
          // Bright warm white
          addR = 255 * grainedIntensity * 0.4
          addG = 240 * grainedIntensity * 0.35
          addB = 200 * grainedIntensity * 0.25
        } else {
          // Warm orange-red
          addR = 255 * grainedIntensity * 0.5
          addG = 140 * grainedIntensity * 0.3
          addB = 80 * grainedIntensity * 0.15
        }
      } else if (isEdgeZone) {
        // EDGE ZONE on shadow side - harsh red/orange, color varies with setting
        // colorSetting: 0 = more red, 1 = more warm/amber
        const redShift = 1 - colorSetting * 0.4
        addR = 255 * grainedIntensity * 0.9 * redShift
        addG = (100 + colorSetting * 80) * grainedIntensity * 0.5
        addB = (40 + colorSetting * 60) * grainedIntensity * 0.2
      } else {
        // OUTER ZONE - softer amber glow
        addR = 255 * grainedIntensity * 0.7
        addG = (160 + colorSetting * 40) * grainedIntensity * 0.45
        addB = (100 + colorSetting * 50) * grainedIntensity * 0.25
      }
      
      // Apply additively - this "warms" existing warm pixels further
      pixels[pixelIdx] = Math.min(255, Math.round(baseR + addR))
      pixels[pixelIdx + 1] = Math.min(255, Math.round(baseG + addG))
      pixels[pixelIdx + 2] = Math.min(255, Math.round(baseB + addB))
    }
    
    ctx.putImageData(processedData, 0, 0)
  }

  // Create a topographic opacity map based on the brightness of the original image
  const createTopoOpacityMap = async (
    originalCtx: CanvasRenderingContext2D,
    width: number,
    height: number,
  ): Promise<Uint8ClampedArray> => {
    // Get the image data from the original image
    const imageData = originalCtx.getImageData(0, 0, width, height)
    const data = imageData.data

    // Create an opacity map with the same dimensions
    const opacityMap = new Uint8ClampedArray(width * height)

    // Process in chunks to avoid UI freezing
    const chunkSize = 1000000 // Process 1M pixels at a time
    const totalPixels = width * height
    const totalChunks = Math.ceil(totalPixels / chunkSize)

    for (let chunk = 0; chunk < totalChunks; chunk++) {
      const start = chunk * chunkSize
      const end = Math.min(start + chunkSize, totalPixels)

      // Process this chunk of pixels
      for (let i = start; i < end; i++) {
        const idx = i * 4

        // Calculate brightness (0-255)
        // Using the luminance formula: 0.299R + 0.587G + 0.114B
        const brightness = Math.round(0.299 * data[idx] + 0.587 * data[idx + 1] + 0.114 * data[idx + 2])

        // Map brightness to opacity with smooth interpolation:
        // - Highlights (brightness > highlightThreshold): interpolate from highlightOpacity% to midtoneOpacity% opacity
        // - Midtones (brightness midtoneThreshold-highlightThreshold): interpolate from midtoneOpacity% to shadowOpacity%
        // - Shadows (brightness < midtoneThreshold): shadowOpacity%
        let opacity: number

        if (brightness > highlightThreshold) {
          // Highlights: smoothly interpolate between highlightOpacity% and midtoneOpacity% opacity
          // Map brightness 255-highlightThreshold to opacity highlightOpacity%-midtoneOpacity%
          const t = (255 - brightness) / (255 - highlightThreshold) // 0 at brightness 255, 1 at brightness highlightThreshold
          const minOpacity = Math.round((highlightOpacity / 100) * 255) // Convert percentage to 0-255
          const maxOpacity = Math.round((midtoneOpacity / 100) * 255) // Convert percentage to 0-255
          opacity = Math.round(minOpacity + t * (maxOpacity - minOpacity))
        } else if (brightness > midtoneThreshold) {
          // Midtones: interpolate between midtoneOpacity% and shadowOpacity%
          // Map brightness highlightThreshold-midtoneThreshold to opacity midtoneOpacity%-shadowOpacity%
          const t = (highlightThreshold - brightness) / (highlightThreshold - midtoneThreshold) // 0 at brightness highlightThreshold, 1 at brightness midtoneThreshold
          const minOpacity = Math.round((midtoneOpacity / 100) * 255) // Convert percentage to 0-255
          const maxOpacity = Math.round((shadowOpacity / 100) * 255) // Convert percentage to 0-255
          opacity = Math.round(minOpacity + t * (maxOpacity - minOpacity))
        } else {
          // Shadows: shadowOpacity%
          opacity = Math.round((shadowOpacity / 100) * 255)
        }

        // Store the opacity value
        opacityMap[i] = opacity
      }

      // Yield to browser to prevent UI freezing
      if (chunk % 5 === 0) {
        await new Promise((resolve) => setTimeout(resolve, 0))
      }
    }

    return opacityMap
  }

  // Apply the processed image with variable opacity based on the topographic map
  const applyProcessedImageWithTopoMap = async (
    targetCtx: CanvasRenderingContext2D,
    processedCanvas: HTMLCanvasElement,
    originalCtx: CanvasRenderingContext2D,
    opacityMap: Uint8ClampedArray,
    width: number,
    height: number,
  ) => {
    // Create a temporary canvas for the opacity-adjusted processed image
    const adjustedCanvas = document.createElement("canvas")
    adjustedCanvas.width = width
    adjustedCanvas.height = height
    const adjustedCtx = adjustedCanvas.getContext("2d", { willReadFrequently: true })
    if (!adjustedCtx) return

    // Get the processed image data
    const processedCtx = processedCanvas.getContext("2d", { willReadFrequently: true })
    if (!processedCtx) return

    // Draw the processed image to the adjusted canvas
    adjustedCtx.drawImage(processedCanvas, 0, 0)

    // Get the image data from the processed image
    const processedData = adjustedCtx.getImageData(0, 0, width, height)
    const data = processedData.data

    // Process in chunks to avoid UI freezing
    const chunkSize = 1000000 // Process 1M pixels at a time
    const totalPixels = width * height
    const totalChunks = Math.ceil(totalPixels / chunkSize)

    for (let chunk = 0; chunk < totalChunks; chunk++) {
      const start = chunk * chunkSize
      const end = Math.min(start + chunkSize, totalPixels)

      // Process this chunk of pixels
      for (let i = start; i < end; i++) {
        const idx = i * 4

        // Get the opacity for this pixel (0-255)
        const opacity = opacityMap[i] / 255 // Convert to 0-1 range

        // Apply the opacity to the alpha channel of the processed image
        // Keep RGB values unchanged, only modify alpha
        data[idx + 3] = Math.round(data[idx + 3] * opacity)
      }

      // Yield to browser occasionally to prevent UI freezing
      if (chunk % 5 === 0) {
        await new Promise((resolve) => setTimeout(resolve, 0))
      }
    }

    // Put the opacity-adjusted image data back to the adjusted canvas
    adjustedCtx.putImageData(processedData, 0, 0)

    // First draw the original image as the background layer
    targetCtx.drawImage(originalCtx.canvas, 0, 0)

    // Then draw the opacity-adjusted processed image on top
    targetCtx.drawImage(adjustedCanvas, 0, 0)

    console.log("Applied topographic opacity map to processed image and layered over original")
  }

  // Process a chunk of the image
  const processChunk = async (
    originalCtx: CanvasRenderingContext2D,
    resultCtx: CanvasRenderingContext2D,
    verificationCtx: CanvasRenderingContext2D,
    boundaryHeatMap: number[][],
    startX: number,
    startY: number,
    chunkWidth: number,
    chunkHeight: number,
    tileSize: number,
    macroTileSize: number,
    onProgress: (tilesProcessed: number) => void,
    MAX_CIRCLES: number,
    circleSizes: { minSize: number; maxSize: number; scaleFactor: number },
    algo2SourceData?: ImageData,
  ): Promise<CircleData[]> => {
    const chunkCircles: CircleData[] = []
    let macroTilesProcessed = 0

    // Process each macro tile in this chunk
    for (let macroY = startY; macroY < startY + chunkHeight; macroY += macroTileSize) {
      for (let macroX = startX; macroX < startX + chunkWidth; macroX += macroTileSize) {
        try {
          // Get the actual macro tile dimensions (handling edge cases)
          const actualMacroWidth = Math.min(macroTileSize, originalCtx.canvas.width - macroX)
          const actualMacroHeight = Math.min(macroTileSize, originalCtx.canvas.height - macroY)

          // Skip if dimensions are invalid
          if (actualMacroWidth <= 0 || actualMacroHeight <= 0) {
            break
          }

          // Create a canvas for this macro tile
          const macroCanvas = document.createElement("canvas")
          macroCanvas.width = actualMacroWidth
          macroCanvas.height = actualMacroHeight
          const macroCtx = macroCanvas.getContext("2d")
          if (!macroCtx) {
            break
          }

          // For algo2: draw directly to resultCtx (skip macro tile canvas to avoid seams)
          // For normal: copy from original context to macro tile canvas
          if (useAlgo2 && algo2SourceData) {
            // Store the full source data on resultCtx for direct drawing
            ;(resultCtx as any)._algo2SourceData = algo2SourceData
            ;(resultCtx as any)._algo2MacroOffset = { x: macroX, y: macroY }
          } else if (!useAlgo2) {
            // Copy the original image data for this macro tile
            macroCtx.drawImage(
              originalCtx.canvas,
              macroX,
              macroY,
              actualMacroWidth,
              actualMacroHeight,
              0,
              0,
              actualMacroWidth,
              actualMacroHeight,
            )
          }

          // Store circles for each tile
          const macroTileCircles: { [key: string]: CircleData[] } = {}

          // Process each tile within the macro tile
          for (let tileY = 0; tileY < actualMacroHeight; tileY += tileSize) {
            for (let tileX = 0; tileX < actualMacroWidth; tileX += tileSize) {
              // Get the actual tile dimensions (handling edge cases)
              const actualTileWidth = Math.min(tileSize, actualMacroWidth - tileX)
              const actualTileHeight = Math.min(tileSize, actualMacroHeight - tileY)

              // Skip if dimensions are invalid
              if (actualTileWidth <= 0 || actualTileHeight <= 0) {
                break
              }

              // Process this individual tile and get the circles
              // For algo2: draw directly to resultCtx with global coordinates
              // For normal: draw to macroCtx with local coordinates
              const tileCircles = useAlgo2
                ? processTileAlgo2(resultCtx, macroX + tileX, macroY + tileY, actualTileWidth, actualTileHeight, circleSizes, resultCtx)
                : processTile(macroCtx, tileX, tileY, actualTileWidth, actualTileHeight, circleSizes, midtoneThreshold, shadowOvalSize / 100, shadowColorDensity / 100, shadowBrightness / 100)

              // Store the circles for this tile
              const tileKey = `${tileX},${tileY}`
              macroTileCircles[tileKey] = tileCircles

              // Add circles to chunk collection with adjusted coordinates, but limit the total
              if (chunkCircles.length < MAX_CIRCLES) {
                const spaceLeft = MAX_CIRCLES - chunkCircles.length
                if (tileCircles.length <= spaceLeft) {
                  tileCircles.forEach((circle) => {
                    chunkCircles.push({
                      ...circle,
                      x: circle.x + tileX + macroX,
                      y: circle.y + tileY + macroY,
                    })
                  })
                } else {
                  tileCircles.slice(0, spaceLeft).forEach((circle) => {
                    chunkCircles.push({
                      ...circle,
                      x: circle.x + tileX + macroX,
                      y: circle.y + tileY + macroY,
                    })
                  })
                }
              }

              // Mark this tile as processed in the verification canvas
              verificationCtx.clearRect(macroX + tileX, macroY + tileY, actualTileWidth, actualTileHeight)
            }
          }

          // Analyze boundaries between tiles within this macro tile
          analyzeTileBoundaries(
            macroCtx,
            macroTileCircles,
            boundaryHeatMap,
            macroX,
            macroY,
            actualMacroWidth,
            actualMacroHeight,
          )

          // Draw the processed macro tile onto the result canvas
          // Skip for algo2 since we draw directly to resultCtx
          if (!useAlgo2) {
            resultCtx.drawImage(macroCanvas, macroX, macroY)
          }

          macroTilesProcessed++

          // Update progress
          onProgress(1)

          // Yield to browser occasionally to prevent UI freezing
          if (macroTilesProcessed % 4 === 0) {
            await new Promise((resolve) => setTimeout(resolve, 0))
          }
        } catch (error) {
          console.error(`Error processing macro tile at ${macroX},${macroY}:`, error)
          // Continue with other tiles even if one fails
        }
      }
    }

    return chunkCircles
  }

