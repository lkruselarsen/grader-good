          )}
        </div>
      </div>

      {/* Detail view */}
      <div className="border rounded-lg overflow-hidden">
        <h3 className="p-2 text-sm font-medium bg-muted">Detail Preview</h3>
        <div className="p-2">
          <p className="text-xs text-muted-foreground mb-2">Double-tap the main image to move this preview area</p>
          <canvas ref={detailCanvasRef} className="w-full aspect-square" />
        </div>
      </div>

      {/* Topographic opacity controls */}
      <div className="space-y-4 py-2">
        <div className="flex items-center space-x-2">
          <Switch id="topo-opacity" checked={useTopoOpacity} onCheckedChange={setUseTopoOpacity} />
          <Label htmlFor="topo-opacity" className="text-sm">
            Topographic opacity (highlights: {highlightOpacity}%, midtones: {midtoneOpacity}%, shadows: 100%)
          </Label>
        </div>

        {useTopoOpacity && (
          <div className="space-y-2">
            <Label htmlFor="highlight-opacity" className="text-sm text-muted-foreground">
              Highlight opacity: {highlightOpacity}%
            </Label>
            <Slider
              id="highlight-opacity"
              min={1}
              max={25}
              step={1}
              value={[highlightOpacity]}
              onValueChange={(value) => setHighlightOpacity(value[0])}
              className="w-full"
            />

            <Label htmlFor="midtone-opacity" className="text-sm text-muted-foreground">
              Midtone opacity: {midtoneOpacity}%
            </Label>
            <Slider
              id="midtone-opacity"
              min={2}
              max={100}
              step={1}
              value={[midtoneOpacity]}
              onValueChange={(value) => setMidtoneOpacity(value[0])}
              className="w-full"
            />

  <Label htmlFor="shadow-opacity" className="text-sm text-muted-foreground">
  Shadow opacity: {shadowOpacity}%
  </Label>
  <Slider
  id="shadow-opacity"
  min={50}
  max={100}
  step={1}
  value={[shadowOpacity]}
  onValueChange={(value) => setShadowOpacity(value[0])}
  className="w-full"
  />
  
  <Label htmlFor="highlight-threshold" className="text-sm text-muted-foreground">
  Highlight threshold: {highlightThreshold} (brightness above this is highlight)
  </Label>
  <Slider
  id="highlight-threshold"
  min={150}
  max={240}
  step={5}
  value={[highlightThreshold]}
  onValueChange={(value) => setHighlightThreshold(value[0])}
  className="w-full"
  />
  
  <Label htmlFor="midtone-threshold" className="text-sm text-muted-foreground">
  Midtone threshold: {midtoneThreshold} (brightness below this is shadow)
  </Label>
  <Slider
  id="midtone-threshold"
  min={5}
  max={150}
  step={5}
  value={[midtoneThreshold]}
  onValueChange={(value) => setMidtoneThreshold(value[0])}
  className="w-full"
  />
  
  <Label htmlFor="shadow-oval-size" className="text-sm text-muted-foreground">
  Shadow oval size: {shadowOvalSize}%
  </Label>
  <Slider
  id="shadow-oval-size"
  min={100}
  max={300}
  step={10}
  value={[shadowOvalSize]}
  onValueChange={(value) => setShadowOvalSize(value[0])}
  className="w-full"
  />
  
  <Label htmlFor="shadow-color-density" className="text-sm text-muted-foreground">
  Shadow color density: {shadowColorDensity}%
  </Label>
  <Slider
  id="shadow-color-density"
  min={100}
  max={250}
  step={10}
  value={[shadowColorDensity]}
  onValueChange={(value) => setShadowColorDensity(value[0])}
  className="w-full"
  />
  
  <Label htmlFor="shadow-brightness" className="text-sm text-muted-foreground">
  Shadow brightness: {shadowBrightness}%
  </Label>
  <Slider
  id="shadow-brightness"
  min={50}
  max={100}
  step={5}
  value={[shadowBrightness]}
  onValueChange={(value) => setShadowBrightness(value[0])}
  className="w-full"
  />
  </div>
  )}
      </div>

      {/* Algo2 checkbox - additive RGB algorithm */}
      <div className="flex items-center gap-2 p-2 border rounded-lg bg-muted/30">
        <input
          type="checkbox"
          id="algo2-toggle"
          checked={useAlgo2}
          onChange={(e) => setUseAlgo2(e.target.checked)}
          className="w-4 h-4"
        />
        <label htmlFor="algo2-toggle" className="text-sm font-medium">
          Algo2 (Additive RGB)
        </label>
      </div>

      {/* Halation settings - hidden when algo2 is enabled */}
      {!useAlgo2 && (
        <>
          {/* Halation button with toggle */}
          <div className="flex items-center gap-2">
            <Switch
              id="halation-toggle"
              checked={halationSettings.enabled}
              onCheckedChange={(checked) => setHalationSettings(prev => ({ ...prev, enabled: checked }))}
            />
            <Button onClick={() => setHalationModalOpen(true)} variant="outline" className="flex-1 bg-transparent">
              Halation Settings
            </Button>
          </div>
          
          {/* Contour Halation toggle with strength */}
          <div className="flex items-center gap-2">
            <Switch
              id="contour-halation-toggle"
              checked={contourHalationEnabled}
              onCheckedChange={setContourHalationEnabled}
            />
            <span className="text-sm flex-1">Contour Halation</span>
            <div className="flex gap-1">
              {[1, 2, 3].map((strength) => (
                <Button
                  key={strength}
                  variant={contourHalationStrength === strength ? "default" : "outline"}
                  size="sm"
                  className={`w-8 h-8 p-0 ${contourHalationStrength !== strength ? "bg-transparent" : ""}`}
                  onClick={() => setContourHalationStrength(strength as 1 | 2 | 3)}
                  disabled={!contourHalationEnabled}
                >
                  {strength}
                </Button>
              ))}
            </div>
          </div>
        </>
      )}
  
  {/* Fine Grain toggle with strength and extra chroma */}
  <div className="flex items-center gap-2">
  <Switch
  id="fine-grain-toggle"
  checked={fineGrainEnabled}
  onCheckedChange={setFineGrainEnabled}
  />
  <span className="text-sm flex-1">Fine Grain</span>
  <div className="flex gap-1">
  {(["normal", "strong"] as const).map((strength) => (
  <Button
  key={strength}
  variant={fineGrainStrength === strength ? "default" : "outline"}
  size="sm"
  className={`px-2 h-8 text-xs ${fineGrainStrength !== strength ? "bg-transparent" : ""}`}
  onClick={() => setFineGrainStrength(strength)}
  disabled={!fineGrainEnabled}
  >
  {strength === "normal" ? "Norm" : "Strong"}
  </Button>
  ))}
  </div>
  </div>
  
  {/* Extra Chroma checkbox - only visible when fine grain is enabled */}
  {fineGrainEnabled && (
  <div className="flex items-center gap-2 pl-12">
  <input
  type="checkbox"
  id="extra-chroma"
  checked={fineGrainExtraChroma}
  onChange={(e) => setFineGrainExtraChroma(e.target.checked)}
  className="h-4 w-4 rounded border-border"
  />
  <label htmlFor="extra-chroma" className="text-sm text-muted-foreground">
  Extra Chroma
  </label>
  </div>
  )}
  
  {/* Halation Modal */}
  <Dialog open={halationModalOpen} onOpenChange={setHalationModalOpen}>
        <DialogContent className="max-w-[95vw] max-h-[95vh] w-full h-full flex flex-col">
          <DialogHeader>
            <DialogTitle>Halation Settings</DialogTitle>
            <DialogDescription>
              Halation simulates the red/orange glow that appears in 35mm film when light bounces off the camera
              pressure plate into shadow areas near highlights.
            </DialogDescription>
          </DialogHeader>

          <div className="flex-1 overflow-auto space-y-4">
            {/* Preview canvas */}
            <div className="border rounded-lg overflow-hidden">
              <canvas ref={halationPreviewCanvasRef} className="w-full h-auto max-h-[50vh] object-contain" />
              <div className="p-2 text-xs text-muted-foreground">
                <span className="inline-block w-3 h-3 bg-cyan-400 mr-1"></span> Highlight edges
                <span className="inline-block w-3 h-3 bg-fuchsia-500 ml-3 mr-1"></span> Shadow edges
                <span className="ml-3">Halation appears where shadow edges are near highlight edges</span>
              </div>
            </div>

            {/* Controls */}
            <div className="space-y-4">
              {/* Enable/disable halation */}
              <div className="flex items-center space-x-2">
                <Switch
                  id="halation-enabled"
                  checked={halationSettings.enabled}
                  onCheckedChange={(checked) => setHalationSettings((prev) => ({ ...prev, enabled: checked }))}
                />
                <Label htmlFor="halation-enabled" className="text-sm">
                  Enable halation effect
                </Label>
              </div>

              {/* Highlight threshold */}
              <div className="space-y-2">
                <Label htmlFor="halation-highlight-threshold" className="text-sm text-muted-foreground">
                  Highlight threshold: {halationSettings.highlightThreshold} (brightness above this is a highlight)
                </Label>
                <Slider
                  id="halation-highlight-threshold"
                  min={150}
                  max={250}
                  step={5}
                  value={[halationSettings.highlightThreshold]}
                  onValueChange={(value) => setHalationSettings((prev) => ({ ...prev, highlightThreshold: value[0] }))}
                  className="w-full"
                />
              </div>

              {/* Shadow threshold */}
              <div className="space-y-2">
                <Label htmlFor="halation-shadow-threshold" className="text-sm text-muted-foreground">
                  Shadow threshold: {halationSettings.shadowThreshold} (brightness below this is a shadow)
                </Label>
                <Slider
                  id="halation-shadow-threshold"
                  min={10}
                  max={150}
                  step={5}
                  value={[halationSettings.shadowThreshold]}
                  onValueChange={(value) => setHalationSettings((prev) => ({ ...prev, shadowThreshold: value[0] }))}
                  className="w-full"
                />
              </div>

              {/* Halation depth */}
              <div className="space-y-2">
                <Label htmlFor="halation-depth" className="text-sm text-muted-foreground">
                  Halation depth: {halationSettings.halationDepth}px (how far the glow extends into shadows)
                </Label>
                <Slider
                  id="halation-depth"
                  min={5}
                  max={50}
                  step={1}
                  value={[halationSettings.halationDepth]}
                  onValueChange={(value) => setHalationSettings((prev) => ({ ...prev, halationDepth: value[0] }))}
                  className="w-full"
                />
              </div>

              {/* Halation color */}
              <div className="space-y-2">
                <Label htmlFor="halation-color" className="text-sm text-muted-foreground">
                  Halation color:{" "}
                  {halationSettings.halationColor <= 0.33
                    ? "Red"
                    : halationSettings.halationColor <= 0.66
                      ? "Orange"
                      : "White"}
                </Label>
                <div className="flex items-center space-x-2">
                  <span className="text-xs">Red</span>
                  <Slider
                    id="halation-color"
                    min={0}
                    max={1}
                    step={0.05}
                    value={[halationSettings.halationColor]}
                    onValueChange={(value) => setHalationSettings((prev) => ({ ...prev, halationColor: value[0] }))}
                    className="flex-1"
                  />
                  <span className="text-xs">White</span>
                </div>
                <div
                  className="h-6 rounded"
                  style={{
                    backgroundColor: (() => {
                      const color = getHalationColor(halationSettings.halationColor)
                      return `rgb(${color.r}, ${color.g}, ${color.b})`
                    })(),
                  }}
                />
              </div>

              {/* Halation opacity */}
              <div className="space-y-2">
                <Label htmlFor="halation-opacity" className="text-sm text-muted-foreground">
                  Halation opacity: {halationSettings.halationOpacity}% (scales down the halation intensity)
                </Label>
<Slider
id="halation-opacity"
min={1}
max={40}
step={1}
                  value={[halationSettings.halationOpacity]}
                  onValueChange={(value) => setHalationSettings((prev) => ({ ...prev, halationOpacity: value[0] }))}
                  className="w-full"
                />
              </div>
            </div>
          </div>

          <DialogFooter>
            <Button variant="outline" onClick={() => setHalationModalOpen(false)} className="bg-transparent">
              Cancel
            </Button>
            <Button
              onClick={() => {
                setHalationModalOpen(false)
              }}
            >
              Save Halation Settings
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Process button (show if not processed OR if settings changed since last process) */}
      {(!processedImage || settingsChangedSinceProcess) && !isProcessing && (
        <div className="flex justify-center">
          <Button onClick={processImage} className="w-full">
            {processedImage && settingsChangedSinceProcess ? "Re-apply Tile Effect" : "Apply Tile Effect"}
          </Button>
        </div>
      )}

      {/* Download button (only show if processed) */}
      {processedImage && (
        <div className="flex justify-center">
          <Button
            onClick={handleDownload}
            onTouchStart={(e) => {
              // Prevent default touch behavior that might interfere
              e.preventDefault()
              handleDownload()
            }}
            className="w-full touch-manipulation"
            style={{
              WebkitTouchCallout: "none",
              WebkitUserSelect: "none",
              touchAction: "manipulation",
            }}
          >
            {/iPad|iPhone|iPod/.test(navigator.userAgent) && !(window as any).MSStream
              ? "Save Image (iOS)"
              : "Download Processed Image"}
          </Button>
        </div>
      )}
    </div>
  )
}
