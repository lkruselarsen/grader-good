      fixedCanvas.width = width
      fixedCanvas.height = height
      const fixedCtx = fixedCanvas.getContext("2d")
      if (!fixedCtx) return

      // Copy the current image
      fixedCtx.drawImage(ctx.canvas, 0, 0)

      // Find high probability boundary areas
      const boundaryThreshold = 0.6 // Threshold for considering an area as a boundary
      const boundaryAreas: { x: number; y: number; width: number; height: number; isHorizontal: boolean }[] = []

      // Check horizontal boundaries at tile and macro tile levels
      for (let y = tileSize; y < height; y += tileSize) {
        // Check if this is a high probability boundary
        let maxProb = 0
        for (let x = 0; x < width; x += Math.max(1, Math.floor(width / 20))) {
          // Sample fewer points
          if (y < boundaryHeatMap.length && x < boundaryHeatMap[0].length) {
            maxProb = Math.max(maxProb, boundaryHeatMap[y][x])
          }
        }

        if (maxProb > boundaryThreshold) {
          boundaryAreas.push({
            x: 0,
            y: y - transitionZoneWidth,
            width,
            height: transitionZoneWidth * 2,
            isHorizontal: true,
          })
        }
      }

      // Check vertical boundaries at tile and macro tile levels
      for (let x = tileSize; x < width; x += tileSize) {
        // Check if this is a high probability boundary
        let maxProb = 0
        for (let y = 0; y < height; y += Math.max(1, Math.floor(height / 20))) {
          // Sample fewer points
          if (y < boundaryHeatMap.length && x < boundaryHeatMap[0].length) {
            maxProb = Math.max(maxProb, boundaryHeatMap[y][x])
          }
        }

        if (maxProb > boundaryThreshold) {
