  // Draw circles to a canvas
  const drawCirclesToCanvas = (ctx: CanvasRenderingContext2D, circles: CircleData[]) => {
    // Process circles in batches to avoid memory issues
    const batchSize = 1000
    const totalBatches = Math.ceil(circles.length / batchSize)

    for (let batch = 0; batch < totalBatches; batch++) {
      const start = batch * batchSize
      const end = Math.min(start + batchSize, circles.length)
      const batchCircles = circles.slice(start, end)

      batchCircles.forEach((circle) => {
        ctx.beginPath()
        ctx.arc(circle.x + circle.size / 2, circle.y + circle.size / 2, circle.size / 2, 0, Math.PI * 2)
        ctx.fillStyle = `rgba(${circle.r}, ${circle.g}, ${circle.b}, ${circle.a})`
        ctx.fill()
      })
    }
  }

  // Process a single tile with randomized parameters and return the circles
  const processTile = (
    ctx: CanvasRenderingContext2D,
    tileX: number,
    tileY: number,
    width: number,
    height: number,
    circleSizes: { minSize: number; maxSize: number; scaleFactor: number },
    shadowThreshold: number,
    shadowSizeMultiplier: number,
    shadowColorDensityMultiplier: number,
    shadowBrightnessMultiplier: number,
  ): CircleData[] => {
    try {
      // Get the image data for this tile
      const tileData = ctx.getImageData(tileX, tileY, width, height)

      // Create a temporary canvas for this tile
      const tileCanvas = document.createElement("canvas")
      tileCanvas.width = width
      tileCanvas.height = height
      const tileCtx = tileCanvas.getContext("2d")

      if (!tileCtx) return []

      // Draw the original tile data
      const tempImageData = new ImageData(new Uint8ClampedArray(tileData.data), width, height)
      tileCtx.putImageData(tempImageData, 0, 0)

      // Arrays to store circles from both passes
      const firstPassCircles: CircleData[] = []
      const secondPassCircles: CircleData[] = []

      // Calculate dynamic step sizes based on scale factor
      const minStep = Math.max(1, Math.round(1 * circleSizes.scaleFactor))
      const maxStep = Math.max(minStep + 1, Math.round(6 * circleSizes.scaleFactor))

      // First pass - start from top left with randomized parameters
      let y = 0
      while (y < height) {
        let x = 0
        while (x < width) {
          // Choose random area size between minSize and maxSize
          let areaSize =
            circleSizes.minSize + Math.floor(Math.random() * (circleSizes.maxSize - circleSizes.minSize + 1))

          // Get average color of the area
          const circleData = getAverageColor(tileCtx, x, y, areaSize)
          if (circleData) {
            // Check if this is a shadow pixel and scale size/color accordingly
            const brightness = 0.299 * circleData.r + 0.587 * circleData.g + 0.114 * circleData.b
            let finalR = circleData.r
            let finalG = circleData.g
            let finalB = circleData.b
            
            if (brightness < shadowThreshold) {
              areaSize = Math.round(areaSize * shadowSizeMultiplier)
              
              // First apply brightness reduction (darkens overall)
              let r = circleData.r * shadowBrightnessMultiplier
              let g = circleData.g * shadowBrightnessMultiplier
              let b = circleData.b * shadowBrightnessMultiplier
              
              // Then boost color density (increases saturation)
              // Convert to grayscale, then push colors away from gray
              const gray = 0.299 * r + 0.587 * g + 0.114 * b
              finalR = Math.min(255, Math.max(0, Math.round(gray + (r - gray) * shadowColorDensityMultiplier)))
              finalG = Math.min(255, Math.max(0, Math.round(gray + (g - gray) * shadowColorDensityMultiplier)))
              finalB = Math.min(255, Math.max(0, Math.round(gray + (b - gray) * shadowColorDensityMultiplier)))
            }
            
            // Store circle in memory
            firstPassCircles.push({
              x,
              y,
              size: areaSize,
              r: finalR,
              g: finalG,
              b: finalB,
              a: circleData.a,
            })
          }

          // Move right by random amount (scaled)
          x += minStep + Math.floor(Math.random() * (maxStep - minStep + 1))
        }

        // Move down by random amount (scaled)
        y += minStep + Math.floor(Math.random() * (maxStep - minStep + 1))
      }

      // Second pass - start with scaled offset and randomized parameters
      const offsetX = Math.max(1, Math.round(3 * circleSizes.scaleFactor))
      const offsetY = Math.max(1, Math.round(2 * circleSizes.scaleFactor))

      y = offsetY
      while (y < height) {
        let x = offsetX
        while (x < width) {
          // Choose random area size between minSize and maxSize
          let areaSize =
            circleSizes.minSize + Math.floor(Math.random() * (circleSizes.maxSize - circleSizes.minSize + 1))

          // Get average color of the area
          const circleData = getAverageColor(tileCtx, x, y, areaSize)
          if (circleData) {
            // Check if this is a shadow pixel and scale size/color accordingly
            const brightness = 0.299 * circleData.r + 0.587 * circleData.g + 0.114 * circleData.b
            let finalR = circleData.r
            let finalG = circleData.g
            let finalB = circleData.b
            
            if (brightness < shadowThreshold) {
              areaSize = Math.round(areaSize * shadowSizeMultiplier)
              
              // First apply brightness reduction (darkens overall)
              let r = circleData.r * shadowBrightnessMultiplier
              let g = circleData.g * shadowBrightnessMultiplier
              let b = circleData.b * shadowBrightnessMultiplier
              
              // Then boost color density (increases saturation)
              // Convert to grayscale, then push colors away from gray
              const gray = 0.299 * r + 0.587 * g + 0.114 * b
              finalR = Math.min(255, Math.max(0, Math.round(gray + (r - gray) * shadowColorDensityMultiplier)))
              finalG = Math.min(255, Math.max(0, Math.round(gray + (g - gray) * shadowColorDensityMultiplier)))
              finalB = Math.min(255, Math.max(0, Math.round(gray + (b - gray) * shadowColorDensityMultiplier)))
            }
            
            // Store circle in memory
            secondPassCircles.push({
              x,
              y,
              size: areaSize,
              r: finalR,
              g: finalG,
              b: finalB,
              a: circleData.a,
            })
          }

          // Move right by random amount (scaled)
          x += minStep + Math.floor(Math.random() * (maxStep - minStep + 1))
        }

        // Move down by random amount (scaled)
        y += minStep + Math.floor(Math.random() * (maxStep - minStep + 1))
      }

      // Reduce opacity of all circles by half
      firstPassCircles.forEach((circle) => {
        circle.a *= 0.5
      })

      secondPassCircles.forEach((circle) => {
        circle.a *= 0.5
      })

      // Clear the tile area on the main canvas
      ctx.clearRect(tileX, tileY, width, height)

      // Combine all circles and make adjustments
      const allCircles = [...firstPassCircles, ...secondPassCircles]

      // Adjust some circles for better interpretation (whole circles at a time)
      allCircles.forEach((circle) => {
        // Randomly adjust about 30% of circles
        if (Math.random() < 0.3) {
          // Adjust color
          const colorAdjust = Math.random() * 30 - 15
          circle.r = Math.max(0, Math.min(255, circle.r + colorAdjust))
          circle.g = Math.max(0, Math.min(255, circle.g + colorAdjust))
          circle.b = Math.max(0, Math.min(255, circle.b + colorAdjust))

          // Adjust transparency (but keep within reasonable bounds)
          const alphaAdjust = Math.random() * 0.2 - 0.1
          circle.a = Math.max(0.1, Math.min(0.9, circle.a + alphaAdjust))
        }
      })

      // Draw all circles onto the main canvas
      allCircles.forEach((circle) => {
        ctx.beginPath()
        ctx.arc(tileX + circle.x + circle.size / 2, tileY + circle.y + circle.size / 2, circle.size / 2, 0, Math.PI * 2)
        ctx.fillStyle = `rgba(${circle.r}, ${circle.g}, ${circle.b}, ${circle.a})`
        ctx.fill()
      })

      // Return all circles for boundary analysis
      return allCircles
    } catch (error) {
      console.error(`Error processing tile at ${tileX},${tileY}:`, error)
      return [] // Return empty array if processing fails
    }
  }

  // ALGO2: Additive RGB light mixing algorithm
  // Paints on black backdrop using only R, G, B ovals with additive blending
  const processTileAlgo2 = (
    ctx: CanvasRenderingContext2D,
    tileX: number,
    tileY: number,
    width: number,
    height: number,
    circleSizes: { minSize: number; maxSize: number; scaleFactor: number },
    sourceCtx: CanvasRenderingContext2D,
  ): CircleData[] => {
    try {
      // Get the source image data for this tile region
      // Use the pre-stored full source data (avoids reading black backdrop)
      let sourcePixels: Uint8ClampedArray
      const storedSourceData = (ctx as any)._algo2SourceData as ImageData | undefined
      if (storedSourceData) {
        // Extract the tile region from the stored full source data
        // tileX and tileY are now global coordinates
        const fullWidth = storedSourceData.width
        const tilePixels = new Uint8ClampedArray(width * height * 4)
        for (let y = 0; y < height; y++) {
          const srcStart = ((tileY + y) * fullWidth + tileX) * 4
          const dstStart = y * width * 4
          tilePixels.set(storedSourceData.data.subarray(srcStart, srcStart + width * 4), dstStart)
        }
        sourcePixels = tilePixels
      } else {
        const sourceData = sourceCtx.getImageData(tileX, tileY, width, height)
        sourcePixels = sourceData.data
      }

      // Store all ovals we'll draw
      const allCircles: CircleData[] = []

      // Base oval size
      const baseOvalSize = (circleSizes.minSize + circleSizes.maxSize) / 2 / 1.5
      
      // Use tight grid for good coverage (non-shadows)
      const tightStep = Math.max(1, baseOvalSize * 0.2)
      
      // Exposure thresholds
      const shadowThreshold = 38 // Bottom 15% of spectrum
      const transitionEnd = 51 // ~20% - end of transition zone
      
      // === SIMPLEX-LIKE NOISE FOR CLUSTERED SHADOW PATTERN ===
      // Generates a "clump field" that determines where grain is more likely
      const noiseScales = [0.015, 0.04, 0.1] // Large, medium, fine clumps
      const noiseWeights = [0.5, 0.3, 0.2]
      
      // Simple hash function for deterministic randomness
      const hash = (x: number, y: number, seed: number): number => {
        const n = Math.sin(x * 12.9898 + y * 78.233 + seed * 43.12) * 43758.5453
        return n - Math.floor(n)
      }
      
      // Smooth noise with bilinear interpolation
      const smoothNoise = (x: number, y: number, seed: number): number => {
        const ix = Math.floor(x)
        const iy = Math.floor(y)
        const fx = x - ix
        const fy = y - iy
        
        // Smoothstep interpolation
        const sx = fx * fx * (3 - 2 * fx)
        const sy = fy * fy * (3 - 2 * fy)
        
        const n00 = hash(ix, iy, seed)
        const n10 = hash(ix + 1, iy, seed)
        const n01 = hash(ix, iy + 1, seed)
        const n11 = hash(ix + 1, iy + 1, seed)
        
        const nx0 = n00 * (1 - sx) + n10 * sx
        const nx1 = n01 * (1 - sx) + n11 * sx
        return nx0 * (1 - sy) + nx1 * sy
      }
      
      // Multi-octave fractal noise (FBM)
      const clumpNoise = (x: number, y: number): number => {
        let value = 0
        for (let i = 0; i < noiseScales.length; i++) {
          value += smoothNoise(x * noiseScales[i], y * noiseScales[i], i * 100) * noiseWeights[i]
        }
        return value
      }
      
      // === PRE-GENERATE CLUMP FIELD FOR SHADOW AREAS ===
      // This creates the clustered stochastic "meta-pattern"
      // Sample points are generated based on clump probability, not a regular grid
      
      // First pass: Non-shadow areas (brightness >= shadowThreshold) use regular grid
      for (let gridY = 0; gridY < height; gridY += tightStep) {
        for (let gridX = 0; gridX < width; gridX += tightStep) {
          const jitterX = (Math.random() - 0.5) * tightStep * 0.8
          const jitterY = (Math.random() - 0.5) * tightStep * 0.8
          const x = gridX + jitterX
          const y = gridY + jitterY
          
          const sampleX = Math.max(0, Math.min(Math.floor(x), width - 1))
          const sampleY = Math.max(0, Math.min(Math.floor(y), height - 1))
          const pixelIdx = (sampleY * width + sampleX) * 4

          const targetR = sourcePixels[pixelIdx]
          const targetG = sourcePixels[pixelIdx + 1]
          const targetB = sourcePixels[pixelIdx + 2]
          const brightness = (targetR + targetG + targetB) / 3
          
          // Skip shadows - handled in second pass
          if (brightness < shadowThreshold) continue
          if (brightness < 2) continue

          const areaSize = circleSizes.minSize + Math.floor(Math.random() * (circleSizes.maxSize - circleSizes.minSize + 1))
          let ovalSize = areaSize / 1.5
          
          // Slightly enlarge in transition zone
          if (brightness < transitionEnd) {
            const enlargeFactor = 1 - (brightness / transitionEnd)
            ovalSize = ovalSize * (1 + enlargeFactor * 0.5)
          }

          const opacity = 0.07
          const rProb = targetR / 255
          const gProb = targetG / 255
          const bProb = targetB / 255
          const sizeVar = 0.9 + Math.random() * 0.2
          const finalSize = ovalSize * sizeVar
          
          // Calculate shared base position for all channels
          // This ensures R, G, B ovals stack together for proper color blending
          const baseOffsetX = (Math.random() - 0.5) * ovalSize * 0.4
          const baseOffsetY = (Math.random() - 0.5) * ovalSize * 0.4
          const baseX = x + baseOffsetX
          const baseY = y + baseOffsetY
          
          // Micro-jitter: max 1/6th of radius to keep channels co-located
          const microJitter = finalSize * (1/6) * 0.5

          if (Math.random() < rProb) {
            allCircles.push({
              x: baseX + (Math.random() - 0.5) * microJitter,
              y: baseY + (Math.random() - 0.5) * microJitter,
              size: finalSize,
              r: 255, g: 0, b: 0, a: opacity,
            })
          }
          if (Math.random() < gProb) {
            allCircles.push({
              x: baseX + (Math.random() - 0.5) * microJitter,
              y: baseY + (Math.random() - 0.5) * microJitter,
              size: finalSize,
              r: 0, g: 255, b: 0, a: opacity,
            })
          }
          if (Math.random() < bProb) {
            allCircles.push({
              x: baseX + (Math.random() - 0.5) * microJitter,
              y: baseY + (Math.random() - 0.5) * microJitter,
              size: finalSize,
              r: 0, g: 0, b: 255, a: opacity,
            })
          }
        }
      }
      
      // === SECOND PASS: SHADOW AREAS WITH CLUSTERED STOCHASTIC PATTERN ===
      // Use Poisson-like sampling with clump field as probability modulator
      
      const shadowStep = Math.max(2, baseOvalSize * 0.4) // Base step for shadow sampling
      const numShadowPasses = 3 // Multiple passes for layered texture
      
      for (let pass = 0; pass < numShadowPasses; pass++) {
        // Each pass uses slightly different noise offset for variety
        const passOffset = pass * 1000
        
        for (let gridY = 0; gridY < height; gridY += shadowStep) {
          for (let gridX = 0; gridX < width; gridX += shadowStep) {
            // Get global coordinates for noise sampling
            const globalX = tileX + gridX
            const globalY = tileY + gridY
            
            // Sample clump field at this position
            const clumpValue = clumpNoise(globalX + passOffset, globalY + passOffset)
            
            // Clump field modulates probability of placing a grain here
            // Higher clump value = more likely to place grains (clustered effect)
            const clumpProbability = clumpValue * clumpValue // Square for more contrast
            
            // Skip based on clump probability - creates the clustered pattern
            if (Math.random() > clumpProbability * 1.5) continue
            
            // Add stochastic jitter within the cell (smaller than non-shadow)
            const jitterX = (Math.random() - 0.5) * shadowStep * 0.6
            const jitterY = (Math.random() - 0.5) * shadowStep * 0.6
            const x = gridX + jitterX
            const y = gridY + jitterY
            
            const sampleX = Math.max(0, Math.min(Math.floor(x), width - 1))
            const sampleY = Math.max(0, Math.min(Math.floor(y), height - 1))
            const pixelIdx = (sampleY * width + sampleX) * 4

            const targetR = sourcePixels[pixelIdx]
            const targetG = sourcePixels[pixelIdx + 1]
            const targetB = sourcePixels[pixelIdx + 2]
            const brightness = (targetR + targetG + targetB) / 3
            
            // Only process shadow areas (bottom 15%)
            if (brightness >= shadowThreshold) continue
            if (brightness < 2) continue
            
            const areaSize = circleSizes.minSize + Math.floor(Math.random() * (circleSizes.maxSize - circleSizes.minSize + 1))
            // Larger ovals in shadows for texture
            let ovalSize = (areaSize / 1.5) * (1.5 + (1 - brightness / shadowThreshold) * 1.0)
            
            // Opacity: use current proven values
            const opacity = 0.01 + (brightness / shadowThreshold) * 0.06
            
            const rProb = targetR / 255
            const gProb = targetG / 255
            const bProb = targetB / 255
            const sizeVar = 0.85 + Math.random() * 0.3
            const finalSize = ovalSize * sizeVar
            
            // Calculate shared base position for all channels
            // This ensures R, G, B ovals stack together for proper color blending
            const baseOffsetX = (Math.random() - 0.5) * ovalSize * 0.3
            const baseOffsetY = (Math.random() - 0.5) * ovalSize * 0.3
            const baseX = x + baseOffsetX
            const baseY = y + baseOffsetY
            
            // Micro-jitter: max 1/6th of radius to keep channels co-located
            const microJitter = finalSize * (1/6) * 0.5

            if (Math.random() < rProb) {
              allCircles.push({
                x: baseX + (Math.random() - 0.5) * microJitter,
                y: baseY + (Math.random() - 0.5) * microJitter,
                size: finalSize,
                r: 255, g: 0, b: 0, a: opacity,
              })
            }
            if (Math.random() < gProb) {
              allCircles.push({
                x: baseX + (Math.random() - 0.5) * microJitter,
                y: baseY + (Math.random() - 0.5) * microJitter,
                size: finalSize,
                r: 0, g: 255, b: 0, a: opacity,
              })
            }
            if (Math.random() < bProb) {
              allCircles.push({
                x: baseX + (Math.random() - 0.5) * microJitter,
                y: baseY + (Math.random() - 0.5) * microJitter,
                size: finalSize,
                r: 0, g: 0, b: 255, a: opacity,
              })
            }
          }
        }
      }

      // Draw all ovals using additive blending (lighter composite operation)
      ctx.globalCompositeOperation = "lighter"
      
      allCircles.forEach((circle) => {
        ctx.beginPath()
        ctx.arc(
          tileX + circle.x + circle.size / 2,
          tileY + circle.y + circle.size / 2,
          circle.size / 2,
          0,
          Math.PI * 2
        )
        ctx.fillStyle = `rgba(${circle.r}, ${circle.g}, ${circle.b}, ${circle.a})`
        ctx.fill()
      })

      // Reset composite operation
      ctx.globalCompositeOperation = "source-over"

      return allCircles
    } catch (error) {
      console.error(`Error processing tile (algo2) at ${tileX},${tileY}:`, error)
      return []
    }
  }

  // Analyze boundaries between tiles within a macro tile
  const analyzeTileBoundaries = (
    ctx: CanvasRenderingContext2D,
    macroTileCircles: { [key: string]: CircleData[] },
    boundaryHeatMap: number[][],
    macroX: number,
    macroY: number,
    width: number,
    height: number,
  ) => {
    const tileSize = 150
    const analysisWidth = 30 // Width of analysis zone on each side of boundary

    // Analyze horizontal boundaries
    for (let tileY = tileSize; tileY < height; tileY += tileSize) {
      if (tileY >= height) break

      for (let tileX = 0; tileX < width; tileX += tileSize) {
        const topTileKey = `${tileX},${tileY - tileSize}`
        const bottomTileKey = `${tileX},${tileY}`

        if (!macroTileCircles[topTileKey] || !macroTileCircles[bottomTileKey]) break

        // Get circles near the boundary
        const topCircles = macroTileCircles[topTileKey].filter(
          (circle) => circle.y + circle.size / 2 > tileSize - analysisWidth,
        )
        const bottomCircles = macroTileCircles[bottomTileKey].filter(
          (circle) => circle.y - circle.size / 2 < analysisWidth,
        )

        // Analyze the boundary
        const boundaryAnalysis = analyzeCircleBoundary(
          topCircles,
          bottomCircles,
          true,
          ctx,
          tileX,
          tileY - analysisWidth,
          Math.min(tileSize, width - tileX),
          analysisWidth * 2,
        )

        // Update the heat map
        updateBoundaryHeatMap(
          boundaryHeatMap,
          macroX + tileX,
          macroY + tileY - analysisWidth,
          Math.min(tileSize, width - tileX),
          analysisWidth * 2,
          boundaryAnalysis.boundaryProbability,
          true,
        )
      }
    }

    // Analyze vertical boundaries
    for (let tileX = tileSize; tileX < width; tileX += tileSize) {
      if (tileX >= width) break

      for (let tileY = 0; tileY < height; tileY += tileSize) {
        const leftTileKey = `${tileX - tileSize},${tileY}`
        const rightTileKey = `${tileX},${tileY}`

        if (!macroTileCircles[leftTileKey] || !macroTileCircles[rightTileKey]) break

        // Get circles near the boundary
        const leftCircles = macroTileCircles[leftTileKey].filter(
          (circle) => circle.x + circle.size / 2 > tileSize - analysisWidth,
        )
        const rightCircles = macroTileCircles[rightTileKey].filter(
          (circle) => circle.x - circle.size / 2 < analysisWidth,
        )

        // Analyze the boundary
        const boundaryAnalysis = analyzeCircleBoundary(
          leftCircles,
          rightCircles,
          false,
          ctx,
          tileX - analysisWidth,
          tileY,
          analysisWidth * 2,
          Math.min(tileSize, height - tileY),
        )

        // Update the heat map
        updateBoundaryHeatMap(
          boundaryHeatMap,
          macroX + tileX - analysisWidth,
          macroY + tileY,
          analysisWidth * 2,
          Math.min(tileSize, height - tileY),
          boundaryAnalysis.boundaryProbability,
          false,
        )
      }
    }
  }

  // Analyze a boundary between two sets of circles
  const analyzeCircleBoundary = (
    circlesA: CircleData[],
    circlesB: CircleData[],
    isHorizontal: boolean,
    ctx: CanvasRenderingContext2D,
    x: number,
    y: number,
    width: number,
    height: number,
  ): BoundaryAnalysis => {
    try {
      // Calculate statistics for both sets of circles
      const statsA = calculateCircleStatistics(circlesA)
      const statsB = calculateCircleStatistics(circlesB)

      // 1. Analyze color discontinuity
      const colorDiscontinuity = calculateColorDiscontinuity(statsA.avgColor, statsB.avgColor)

      // 2. Analyze pattern discontinuity
      const patternDiscontinuity =
        Math.abs(statsA.sizeVariance - statsB.sizeVariance) /
        Math.max(0.1, (statsA.sizeVariance + statsB.sizeVariance) / 2)

      // 3. Analyze density change
      const densityChange =
        Math.abs(statsA.density - statsB.density) / Math.max(0.1, (statsA.density + statsB.density) / 2)

      // 4. Detect unnatural alignments
      const alignmentScore = detectCircleAlignment(circlesA.concat(circlesB), isHorizontal)

      // 5. Examine texture coherence
      const textureCoherence = calculateTextureCoherence(ctx, x, y, width, height, isHorizontal)

      // Calculate overall boundary probability (weighted sum)
      const boundaryProbability =
        colorDiscontinuity * 0.25 +
        patternDiscontinuity * 0.2 +
        densityChange * 0.2 +
        alignmentScore * 0.25 +
        (1 - textureCoherence) * 0.1

      return {
        colorDiscontinuity,
        patternDiscontinuity,
        densityChange,
        alignmentScore,
        textureCoherence,
        boundaryProbability,
      }
    } catch (error) {
      console.error("Error in analyzeCircleBoundary:", error)
      // Return default values if analysis fails
      return {
        colorDiscontinuity: 0.5,
        patternDiscontinuity: 0.5,
        densityChange: 0.5,
        alignmentScore: 0.5,
        textureCoherence: 0.5,
        boundaryProbability: 0.5,
      }
    }
  }

  // Calculate statistics for a set of circles
  const calculateCircleStatistics = (circles: CircleData[]): CircleStatistics => {
    if (circles.length === 0) {
      return {
        avgSize: 0,
        sizeVariance: 0,
        avgColor: { r: 0, g: 0, b: 0 },
        colorVariance: 0,
        density: 0,
        avgOpacity: 0,
        opacityVariance: 0,
        dominantDirection: null,
      }
    }

    // Calculate average size
    const totalSize = circles.reduce((sum, circle) => sum + circle.size, 0)
    const avgSize = totalSize / circles.length

    // Calculate size variance
    const sizeVariance = circles.reduce((sum, circle) => sum + Math.pow(circle.size - avgSize, 2), 0) / circles.length

    // Calculate average color
    const totalColor = circles.reduce(
      (sum, circle) => ({
        r: sum.r + circle.r,
        g: sum.g + circle.g,
        b: sum.b + circle.b,
      }),
      { r: 0, g: 0, b: 0 },
    )
    const avgColor = {
      r: totalColor.r / circles.length,
      g: totalColor.g / circles.length,
      b: totalColor.b / circles.length,
    }

    // Calculate color variance (simplified as average distance from mean)
    const colorVariance =
      circles.reduce(
        (sum, circle) =>
          sum +
          Math.sqrt(
            Math.pow(circle.r - avgColor.r, 2) +
              Math.pow(circle.g - avgColor.g, 2) +
              Math.pow(circle.b - avgColor.b, 2),
          ),
        0,
      ) / circles.length

    // Calculate density (circles per unit area)
    const totalArea = circles.reduce((sum, circle) => sum + Math.PI * Math.pow(circle.size / 2, 2), 0)
    const density = totalArea / (circles.length > 0 ? circles.length : 1)

    // Calculate average opacity
    const totalOpacity = circles.reduce((sum, circle) => sum + circle.a, 0)
    const avgOpacity = totalOpacity / circles.length

    // Calculate opacity variance
    const opacityVariance =
      circles.reduce((sum, circle) => sum + Math.pow(circle.a - avgOpacity, 2), 0) / circles.length

    // Analyze dominant direction (if any)
    const directions: { [key: string]: number } = {}
    // Limit the number of pairs to analyze to avoid excessive computation
    const maxPairsToAnalyze = 200 // Reduced from 1000 to prevent stack overflow
    const maxCirclesToConsider = Math.min(circles.length, 100) // Limit the number of circles to consider
    const pairsToAnalyze = Math.min(
      maxPairsToAnalyze,
      Math.floor((maxCirclesToConsider * (maxCirclesToConsider - 1)) / 2),
    )

    if (pairsToAnalyze > 0 && maxCirclesToConsider > 1) {
      const pairStep = Math.max(1, Math.floor((maxCirclesToConsider * (maxCirclesToConsider - 1)) / 2 / pairsToAnalyze))
      let pairCount = 0
      let pairIndex = 0

      for (let i = 0; i < maxCirclesToConsider - 1 && pairCount < pairsToAnalyze; i++) {
        for (let j = i + 1; j < maxCirclesToConsider && pairCount < pairsToAnalyze; j++) {
          pairIndex++
          if (pairIndex % pairStep === 0) {
            const dx = circles[j].x - circles[i].x
            const dy = circles[j].y - circles[i].y
            const angle = Math.atan2(dy, dx) * (180 / Math.PI)
            const binned = Math.round(angle / 10) * 10
            directions[binned] = (directions[binned] || 0) + 1
            pairCount++
          }
        }
      }
    }

    let dominantDirection = null
    let maxCount = 0
    for (const [dir, count] of Object.entries(directions)) {
      if (count > maxCount) {
        maxCount = count
        dominantDirection = Number.parseInt(dir)
      }
    }

    return {
      avgSize,
      sizeVariance,
      avgColor,
      colorVariance,
      density,
      avgOpacity,
      opacityVariance,
      dominantDirection,
    }
  }

  // Calculate color discontinuity between two average colors
  const calculateColorDiscontinuity = (
    colorA: { r: number; g: number; b: number },
    colorB: { r: number; g: number; b: number },
  ) => {
    return (
      Math.sqrt(
        Math.pow(colorA.r - colorB.r, 2) + Math.pow(colorA.g - colorB.g, 2) + Math.pow(colorA.b - colorB.b, 2),
      ) / 441.67
    ) // Normalize by max possible distance (sqrt(255^2 * 3))
  }

  // Detect unnatural alignments of circles
  const detectCircleAlignment = (circles: CircleData[], isHorizontal: boolean): number => {
    if (circles.length < 5) return 0

    // Sort circles by position along the boundary
    const sortedCircles = [...circles].sort((a, b) => (isHorizontal ? a.x - b.x : a.y - b.y))

    // Count how many circles are aligned in a grid-like pattern
    let alignedCount = 0
    const alignmentThreshold = 2 // Maximum distance to consider aligned

    for (let i = 0; i < sortedCircles.length - 1; i++) {
      const current = sortedCircles[i]
      const next = sortedCircles[i + 1]

      // Check if circles are aligned perpendicular to the boundary
      const distance = isHorizontal ? Math.abs(current.y - next.y) : Math.abs(current.x - next.x)

      if (distance < alignmentThreshold) {
        alignedCount++
      }
    }

    // Calculate alignment score (0 to 1)
    return alignedCount / (sortedCircles.length - 1)
  }

  // Calculate texture coherence across a boundary
  const calculateTextureCoherence = (
    ctx: CanvasRenderingContext2D,
    x: number,
    y: number,
    width: number,
    height: number,
    isHorizontal: boolean,
  ): number => {
    try {
      // Get image data for the boundary area
      const imageData = ctx.getImageData(x, y, width, height)
      const data = imageData.data

      // Calculate texture features on both sides of the boundary
      const midpoint = isHorizontal ? Math.floor(height / 2) : Math.floor(width / 2)

      // Calculate texture features (simplified as variance in each region)
      const featuresA = calculateTextureFeatures(data, width, height, 0, midpoint, isHorizontal)
      const featuresB = calculateTextureFeatures(
        data,
        width,
        height,
        midpoint,
        isHorizontal ? height : width,
        isHorizontal,
      )

      // Calculate similarity between texture features (higher is more coherent)
      const similarity = calculateFeatureSimilarity(featuresA, featuresB)

      return similarity
    } catch (e) {
      return 0.5 // Default to medium coherence if calculation fails
    }
  }

  // Calculate texture features for a region
  const calculateTextureFeatures = (
    data: Uint8ClampedArray,
    width: number,
    height: number,
    start: number,
    end: number,
    isHorizontal: boolean,
  ): number[] => {
    // Calculate mean and variance for each color channel
    let sumR = 0,
      sumG = 0,
      sumB = 0
    let count = 0

    // Calculate means
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const position = isHorizontal ? y : x
        if (position >= start && position < end) {
          const idx = (y * width + x) * 4
          sumR += data[idx]
          sumG += data[idx + 1]
          sumB += data[idx + 2]
          count++
        }
      }
    }

    const meanR = sumR / count
    const meanG = sumG / count
    const meanB = sumB / count

    // Calculate variances
    let varR = 0,
      varG = 0,
      varB = 0

    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const position = isHorizontal ? y : x
        if (position >= start && position < end) {
          const idx = (y * width + x) * 4
          varR += Math.pow(data[idx] - meanR, 2)
          varG += Math.pow(data[idx + 1] - meanG, 2)
          varB += Math.pow(data[idx + 2] - meanB, 2)
        }
      }
    }

    varR /= count
    varG /= count
    varB /= count

    // Calculate edge density (simplified)
    let edgeCount = 0
    for (let y = 1; y < height; y++) {
      for (let x = 1; x < width; x++) {
        const position = isHorizontal ? y : x
        if (position >= start && position < end) {
          const idx = (y * width + x) * 4
          const idxLeft = (y * width + (x - 1)) * 4
          const idxUp = ((y - 1) * width + x) * 4

          const diffH =
            Math.abs(data[idx] - data[idxLeft]) +
            Math.abs(data[idx + 1] - data[idxLeft + 1]) +
            Math.abs(data[idx + 2] - data[idxLeft + 2])

          const diffV =
            Math.abs(data[idx] - data[idxUp]) +
            Math.abs(data[idx + 1] - data[idxUp + 1]) +
            Math.abs(data[idx + 2] - data[idxUp + 2])

          if (diffH > 100 || diffV > 100) {
            edgeCount++
          }
        }
      }
    }

    const edgeDensity = edgeCount / count

    // Return feature vector
    return [meanR, meanG, meanB, varR, varG, varB, edgeDensity]
  }

  // Calculate similarity between feature vectors
  const calculateFeatureSimilarity = (featuresA: number[], featuresB: number[]): number => {
    // Normalize the feature vectors
    const normalizedA = normalizeFeatures(featuresA)
    const normalizedB = normalizeFeatures(featuresB)

    // Calculate cosine similarity
    let dotProduct = 0
    let normA = 0
    let normB = 0

    for (let i = 0; i < normalizedA.length; i++) {
      dotProduct += normalizedA[i] * normalizedB[i]
      normA += Math.pow(normalizedA[i], 2)
      normB += Math.pow(normalizedB[i], 2)
    }

    normA = Math.sqrt(normA)
    normB = Math.sqrt(normB)

    if (normA === 0 || normB === 0) return 0

    return dotProduct / (normA * normB)
  }

  // Normalize feature vector
  const normalizeFeatures = (features: number[]): number[] => {
    const min = Math.min(...features)
    const max = Math.max(...features)

    if (max === min) return features.map(() => 1)

    return features.map((f) => (f - min) / (max - min))
  }

  // Update the boundary heat map
  const updateBoundaryHeatMap = (
    heatMap: number[][],
    x: number,
    y: number,
    width: number,
    height: number,
    probability: number,
    isHorizontal: boolean,
  ) => {
    // Apply a Gaussian-like distribution centered on the boundary
    const sigma = isHorizontal ? height / 6 : width / 6

    for (let py = 0; py < height; py++) {
      for (let px = 0; px < width; px++) {
        const mapX = x + px
        const mapY = y + py

        if (mapX < 0 || mapX >= heatMap[0].length || mapY < 0 || mapY >= heatMap.length) break

        // Calculate distance from boundary line
        const distance = isHorizontal ? Math.abs(py - height / 2) : Math.abs(px - width / 2)

        // Apply Gaussian falloff
        const weight = Math.exp(-(distance * distance) / (2 * sigma * sigma))

        // Update heat map with weighted probability
        heatMap[mapY][mapX] = Math.max(heatMap[mapY][mapX], probability * weight)
      }
    }
  }

  // Fix global boundaries using the heat map and advanced strategies
  const fixGlobalBoundaries = async (
    ctx: CanvasRenderingContext2D,
    circlesCtx: CanvasRenderingContext2D,
    originalCtx: CanvasRenderingContext2D,
    boundaryHeatMap: number[][],
    allCircles: CircleData[],
    width: number,
    height: number,
    tileSize: number,
