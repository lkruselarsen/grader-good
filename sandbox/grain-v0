      const areasToProcess = boundaryAreas.slice(0, MAX_BOUNDARY_AREAS)
      console.log(`Processing ${areasToProcess.length} of ${boundaryAreas.length} boundary areas`)

      // Fix each boundary area
      for (const area of areasToProcess) {
        try {
          // Get image content type for this area
          const contentType = analyzeImageContent(originalCtx, area.x, area.y, area.width, area.height)

          // Apply appropriate fixing strategy based on content type
          if (contentType === "detailed") {
            await fixDetailedBoundary(fixedCtx, originalCtx, circlesCtx, allCircles, area, transitionZoneWidth)
          } else if (contentType === "uniform") {
            await fixUniformBoundary(fixedCtx, originalCtx, circlesCtx, allCircles, area, transitionZoneWidth)
          } else {
            await fixMixedBoundary(fixedCtx, originalCtx, circlesCtx, allCircles, area, transitionZoneWidth)
